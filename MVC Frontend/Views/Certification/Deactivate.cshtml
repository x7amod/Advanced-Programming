@model Web_API.Models.CertificationTrack
@{
    ViewData["Title"] = "Deactivate Track";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Deactivate Certification Track</h2>
    <a asp-action="Details" asp-route-id="@Model.CertificationTrackId" class="btn btn-outline-secondary">← Cancel</a>
</div>

<div class="card border-danger" style="max-width:520px;">
    <div class="card-header bg-danger text-white">Confirm Deactivation</div>
    <div class="card-body">
        <p>You are about to deactivate the following certification track:</p>
        <dl class="row mb-3">
            <dt class="col-sm-4">Track Name</dt>
            <dd class="col-sm-8"><strong>@Model.Name</strong></dd>
            <dt class="col-sm-4">Required Courses</dt>
            <dd class="col-sm-8">@Model.CertificationRequiredCourses.Count</dd>
            <dt class="col-sm-4">Certifications</dt>
            <dd class="col-sm-8">@Model.TraineeCertifications.Count issued</dd>
        </dl>
        <div class="alert alert-warning mb-3">
            Deactivating this track will hide it from trainees. Existing certificates will not be affected.
        </div>

        <form asp-action="Deactivate" asp-route-id="@Model.CertificationTrackId" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Deactivate</button>
                <a asp-action="Details" asp-route-id="@Model.CertificationTrackId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
