@model IEnumerable<MVC_Frontend.Models.CertificationProgressViewModel>
@{
    ViewData["Title"] = "My Certification Progress";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">My Certification Progress</h2>
    <a asp-action="MyCertificates" class="btn btn-outline-primary">
        🎓 My Certificates
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No active certification tracks found.</div>
}
else
{
    <div class="row g-3">
        @foreach (var vm in Model)
        {
            var status = vm.TraineeCert?.Status?.Status;
            var badgeClass = status switch
            {
                "Issued"   => "bg-success",
                "Eligible" => "bg-warning text-dark",
                "Expired"  => "bg-danger",
                _          => null
            };

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(vm.IsEligible && status != "Issued" ? "border-warning" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@vm.Track.Name</h5>
                            @if (badgeClass != null)
                            {
                                <span class="badge @badgeClass">@status</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(vm.Track.Description))
                        {
                            <p class="card-text text-muted small mb-2">@vm.Track.Description</p>
                        }

                        @if (status == "Issued")
                        {
                            <div class="alert alert-success py-2 mb-2 small">
                                <strong>Certificate issued</strong>
                                @if (vm.TraineeCert?.CertificateIssuedDate.HasValue == true)
                                {
                                    <span> on @vm.TraineeCert.CertificateIssuedDate.Value.ToString("dd MMM yyyy")</span>
                                }
                            </div>
                        }
                        else if (vm.IsEligible)
                        {
                            <div class="alert alert-warning py-2 mb-2 small">
                                You have completed all mandatory courses! Awaiting certificate issuance.
                            </div>
                        }

                        <div class="mb-1">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Mandatory courses completed</span>
                                <span>@vm.CompletedMandatory / @vm.TotalMandatory</span>
                            </div>
                            <div class="progress" style="height:8px;">
                                <div class="progress-bar @(vm.IsEligible ? "bg-success" : "")"
                                     role="progressbar"
                                     style="width:@vm.ProgressPercent%"
                                     aria-valuenow="@vm.ProgressPercent"
                                     aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Progress" asp-route-id="@vm.Track.CertificationTrackId"
                           class="btn btn-sm btn-outline-primary w-100">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
