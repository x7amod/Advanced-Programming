@model MVC_Frontend.Models.CertificationTrackFormViewModel
@{
    ViewData["Title"] = "Edit Certification Track";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Edit Certification Track</h2>
    <a asp-action="Details" asp-route-id="@Model.CertificationTrackId" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.CertificationTrackId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CertificationTrackId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ValidityPeriod" class="form-label fw-semibold"></label>
                <div class="input-group" style="max-width:200px;">
                    <input asp-for="ValidityPeriod" class="form-control" type="number" min="1" max="120" />
                    <span class="input-group-text">months</span>
                </div>
                <div class="form-text">Leave blank for no expiry.</div>
                <span asp-validation-for="ValidityPeriod" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.CertificationTrackId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
