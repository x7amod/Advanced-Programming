@model MVC_Frontend.Models.CertificationProgressViewModel
@{
    ViewData["Title"] = $"Progress – {Model.Track.Name}";
    bool isCoordinator = User.IsInRole("Training Coordinator");
    var certStatus = Model.TraineeCert?.Status?.Status;
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-1">@Model.Track.Name</h2>
        @if (isCoordinator && Model.TraineeName != null)
        {
            <p class="text-muted mb-0">Trainee: <strong>@Model.TraineeName</strong></p>
        }
        @if (!string.IsNullOrEmpty(Model.Track.Description))
        {
            <p class="text-muted small mb-0">@Model.Track.Description</p>
        }
    </div>
    <a asp-action="@(isCoordinator ? "Details" : "MyProgress")"
       asp-route-id="@(isCoordinator ? Model.Track.CertificationTrackId.ToString() : null)"
       class="btn btn-outline-secondary">← Back</a>
</div>

@* ── Progress summary ───────────────────────────────────────── *@
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="fw-semibold">Overall Progress</span>
            @if (certStatus != null)
            {
                var cls = certStatus switch
                {
                    "Issued"   => "bg-success",
                    "Eligible" => "bg-warning text-dark",
                    "Expired"  => "bg-danger",
                    _          => "bg-secondary"
                };
                <span class="badge @cls">@certStatus</span>
            }
        </div>
        <div class="progress mb-2" style="height:14px;">
            <div class="progress-bar @(Model.IsEligible ? "bg-success" : "")"
                 role="progressbar"
                 style="width:@Model.ProgressPercent%"
                 aria-valuenow="@Model.ProgressPercent"
                 aria-valuemin="0" aria-valuemax="100">
                @Model.ProgressPercent%
            </div>
        </div>
        <div class="small text-muted">
            @Model.CompletedMandatory of @Model.TotalMandatory mandatory course(s) passed
        </div>

        @* Certificate details (if issued) *@
        @if (certStatus == "Issued" && Model.TraineeCert != null)
        {
            <hr />
            <div class="row g-2 small">
                <div class="col-sm-4"><strong>Certificate #:</strong><br />
                    <code>@Model.TraineeCert.CertificateNumber</code></div>
                <div class="col-sm-4"><strong>Issued:</strong><br />
                    @Model.TraineeCert.CertificateIssuedDate?.ToString("dd MMM yyyy")</div>
                <div class="col-sm-4"><strong>Expires:</strong><br />
                    @(Model.TraineeCert.ExpiryDate.HasValue
                        ? Model.TraineeCert.ExpiryDate.Value.ToString("dd MMM yyyy")
                        : "No expiry")</div>
            </div>
        }

        @* Eligible but not issued: coordinator action *@
        @if (isCoordinator && Model.IsEligible && certStatus != "Issued")
        {
            <hr />
            <div class="d-flex align-items-center gap-3">
                <span class="text-success fw-semibold">✓ Trainee meets all requirements</span>
                <form asp-action="IssueCertificate" method="post"
                      data-confirm="Issue certificate for @Model.TraineeName?"
                      data-confirm-ok="btn-success"
                      data-confirm-label="Issue Certificate">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="traineeId" value="@Model.TraineeId" />
                    <input type="hidden" name="trackId" value="@Model.Track.CertificationTrackId" />
                    <button type="submit" class="btn btn-success">Issue Certificate</button>
                </form>
            </div>
        }
        else if (!isCoordinator && Model.IsEligible && certStatus != "Issued")
        {
            <hr />
            <div class="alert alert-warning mb-0">
                You have completed all mandatory courses! Contact your coordinator to issue your certificate.
            </div>
        }
    </div>
</div>

@* ── Course table ───────────────────────────────────────────── *@
<div class="card">
    <div class="card-header"><strong>Course Requirements</strong></div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Code</th>
                    <th>Course Title</th>
                    <th>Type</th>
                    <th>Result</th>
                    <th>Completed On</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Courses)
                {
                    <tr class="@(c.IsMandatory && !c.IsCompleted ? "table-light" : "")">
                        <td class="text-muted">@(c.SequenceOrder?.ToString() ?? "—")</td>
                        <td><code>@c.CourseCode</code></td>
                        <td>@c.CourseTitle</td>
                        <td>
                            @if (c.IsMandatory)
                            {
                                <span class="badge bg-danger">Mandatory</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Optional</span>
                            }
                        </td>
                        <td>
                            @if (c.IsCompleted)
                            {
                                <span class="badge bg-success">Pass ✓</span>
                            }
                            else if (c.Result == "Fail")
                            {
                                <span class="badge bg-danger">Fail</span>
                            }
                            else
                            {
                                <span class="text-muted small">Not completed</span>
                            }
                        </td>
                        <td>
                            @(c.CompletionDate.HasValue ? c.CompletionDate.Value.ToString("dd MMM yyyy") : "—")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
