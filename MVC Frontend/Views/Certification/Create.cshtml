@model MVC_Frontend.Models.CertificationTrackFormViewModel
@{
    ViewData["Title"] = "New Certification Track";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">New Certification Track</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Certified Data Analyst" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Describe the certification goals and target audience…"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ValidityPeriod" class="form-label fw-semibold"></label>
                <div class="input-group" style="max-width:200px;">
                    <input asp-for="ValidityPeriod" class="form-control" type="number" min="1" max="120" placeholder="e.g. 24" />
                    <span class="input-group-text">months</span>
                </div>
                <div class="form-text">Leave blank for certificates that do not expire.</div>
                <span asp-validation-for="ValidityPeriod" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active (visible to trainees)</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Track</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
