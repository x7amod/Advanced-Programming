@model MVC_Frontend.Models.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    var jsonOpts = new JsonSerializerOptions();
}

<div class="mb-4">
    <h1 class="h3 mb-1">Welcome back, @Model.UserName 👋</h1>
    <p class="text-muted mb-0">Here's what's happening in your training platform.</p>
</div>

@* ═══════════════════════════════════════════════════════════════ TRAINEE *@
@if (Model.Role == "Trainee" && Model.Trainee != null)
{
    var t = Model.Trainee;

    @* Stat cards *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Total Enrollments</p>
                    <h3 class="mb-0 fw-bold">@t.TotalEnrollments</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Active</p>
                    <h3 class="mb-0 fw-bold text-primary">@t.ActiveEnrollments</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Completed</p>
                    <h3 class="mb-0 fw-bold text-success">@t.CompletedEnrollments</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Outstanding Balance</p>
                    <h3 class="mb-0 fw-bold @(t.Outstanding > 0 ? "text-danger" : "text-success")">
                        @t.Outstanding.ToString("C")
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Enrollment status chart *@
        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Enrollment Breakdown</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    @if (t.EnrollmentCounts.Any())
                    {
                        <canvas id="traineeEnrollChart" style="max-height:220px;"></canvas>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No enrollments yet.</p>
                    }
                </div>
            </div>
        </div>

        @* Upcoming sessions *@
        <div class="col-md-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Upcoming Sessions</div>
                <div class="card-body p-0">
                    @if (!t.UpcomingSessions.Any())
                    {
                        <p class="text-muted small p-3 mb-0">No upcoming sessions.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var s in t.UpcomingSessions)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <p class="mb-0 fw-semibold small">@s.CourseTitle</p>
                                        <small class="text-muted">@s.SessionDate.ToString("ddd, MMM dd") · @s.StartTime.ToString("hh:mm tt") @(s.ClassroomName != null ? "· " + s.ClassroomName : "")</small>
                                    </div>
                                    <span class="badge bg-primary-subtle text-primary rounded-pill">
                                        @((s.SessionDate - DateTime.Today).Days)d
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-controller="Enrollment" asp-action="MyEnrollments" class="small text-decoration-none">View all enrollments →</a>
                </div>
            </div>
        </div>

        @* Certification progress *@
        @if (t.CertProgress.Any())
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-light fw-semibold">Certification Progress</div>
                    <div class="card-body">
                        @foreach (var cp in t.CertProgress)
                        {
                            var barColor = cp.Status == "Issued" ? "bg-success"
                                         : cp.Percentage == 100 ? "bg-info"
                                         : "bg-primary";
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-semibold">@cp.TrackName</span>
                                    <span class="small text-muted">@cp.Completed / @cp.Total courses &nbsp;
                                        <span class="badge @(cp.Status == "Issued" ? "bg-success" : "bg-secondary")">@cp.Status</span>
                                    </span>
                                </div>
                                <div class="progress" style="height:10px;">
                                    <div class="progress-bar @barColor" style="width:@cp.Percentage%"
                                         role="progressbar" aria-valuenow="@cp.Percentage"
                                         aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-controller="Certification" asp-action="MyProgress" class="small text-decoration-none">View certification details →</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ═══════════════════════════════════════════════════════════════ INSTRUCTOR *@
@if (Model.Role == "Instructor" && Model.Instructor != null)
{
    var inst = Model.Instructor;

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Upcoming Sessions</p>
                    <h3 class="mb-0 fw-bold text-primary">@inst.UpcomingSessionCount</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Completed Sessions</p>
                    <h3 class="mb-0 fw-bold text-success">@inst.CompletedSessionCount</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Trainees Assessed</p>
                    <h3 class="mb-0 fw-bold">@inst.TotalTraineesAssessed</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Pass Rate</p>
                    <h3 class="mb-0 fw-bold text-success">
                        @(inst.TotalTraineesAssessed > 0
                            ? $"{(int)Math.Round((double)inst.PassCount / inst.TotalTraineesAssessed * 100)}%"
                            : "—")
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Monthly sessions bar chart *@
        <div class="col-md-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Sessions — Last 6 Months</div>
                <div class="card-body">
                    <canvas id="instMonthChart" style="max-height:220px;"></canvas>
                </div>
            </div>
        </div>

        @* Pass / Fail doughnut *@
        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Assessment Results</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    @if (inst.TotalTraineesAssessed > 0)
                    {
                        <canvas id="instPassChart" style="max-height:200px;"></canvas>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No assessments submitted yet.</p>
                    }
                </div>
            </div>
        </div>

        @* Upcoming sessions list *@
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light fw-semibold">Upcoming Sessions</div>
                <div class="card-body p-0">
                    @if (!inst.UpcomingSessions.Any())
                    {
                        <p class="text-muted small p-3 mb-0">No upcoming sessions scheduled.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr><th>Course</th><th>Date</th><th>Time</th><th>Room</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in inst.UpcomingSessions)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@s.CourseTitle</td>
                                            <td>@s.SessionDate.ToString("ddd, MMM dd yyyy")</td>
                                            <td>@s.StartTime.ToString("hh:mm tt")</td>
                                            <td class="text-muted">@(s.ClassroomName ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-controller="Enrollment" asp-action="MySessions" class="small text-decoration-none">View all sessions →</a>
                </div>
            </div>
        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════ COORDINATOR *@
@if (Model.Role == "Training Coordinator" && Model.Coordinator != null)
{
    var co = Model.Coordinator;

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Total Trainees</p>
                    <h3 class="mb-0 fw-bold text-primary">@co.TotalTrainees</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Instructors</p>
                    <h3 class="mb-0 fw-bold">@co.TotalInstructors</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Active Courses</p>
                    <h3 class="mb-0 fw-bold">@co.TotalActiveCourses</h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted small mb-1">Sessions This Month</p>
                    <h3 class="mb-0 fw-bold text-success">@co.SessionsThisMonth</h3>
                </div>
            </div>
        </div>
    </div>

    @* Revenue summary *@
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Total Invoiced</p>
                    <h4 class="mb-0">@co.TotalInvoiced.ToString("C")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Collected</p>
                    <h4 class="mb-0 text-success">@co.TotalCollected.ToString("C")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Outstanding</p>
                    <h4 class="mb-0 @(co.TotalOutstanding > 0 ? "text-danger" : "text-success")">@co.TotalOutstanding.ToString("C")</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Monthly enrollments line chart *@
        <div class="col-md-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Monthly Enrollments — Last 6 Months</div>
                <div class="card-body">
                    <canvas id="coEnrollChart" style="max-height:220px;"></canvas>
                </div>
            </div>
        </div>

        @* Enrollment status doughnut *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Enrollment Status</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="coStatusChart" style="max-height:220px;"></canvas>
                </div>
            </div>
        </div>

        @* Top 5 courses *@
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Top Courses by Enrollment</div>
                <div class="card-body">
                    <canvas id="coTopChart" style="max-height:220px;"></canvas>
                </div>
            </div>
        </div>

        @* Revenue bar chart *@
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light fw-semibold">Revenue Overview</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="coRevenueChart" style="max-height:220px;"></canvas>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function () {
    var palette = ['#6366f1','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899'];

    function doughnut(id, labels, data) {
        var ctx = document.getElementById(id);
        if (!ctx) return;
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{ data: data, backgroundColor: palette, borderWidth: 2 }]
            },
            options: {
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12 } } },
                cutout: '65%',
                maintainAspectRatio: true
            }
        });
    }

    function bar(id, labels, data, label, color) {
        var ctx = document.getElementById(id);
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{ label: label, data: data, backgroundColor: color || '#6366f1', borderRadius: 6 }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                maintainAspectRatio: true
            }
        });
    }

    function line(id, labels, data, label) {
        var ctx = document.getElementById(id);
        if (!ctx) return;
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: label,
                    data: data,
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99,102,241,0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                maintainAspectRatio: true
            }
        });
    }

    @if (Model.Role == "Trainee" && Model.Trainee != null)
    {
        var tLabels = Model.Trainee.EnrollmentLabels;
        var tCounts = Model.Trainee.EnrollmentCounts;
        <text>
        doughnut('traineeEnrollChart',
            @Html.Raw(JsonSerializer.Serialize(tLabels)),
            @Html.Raw(JsonSerializer.Serialize(tCounts)));
        </text>
    }

    @if (Model.Role == "Instructor" && Model.Instructor != null)
    {
        var iMonthLabels = Model.Instructor.MonthLabels;
        var iMonthCounts = Model.Instructor.MonthSessionCounts;
        var passCount = Model.Instructor.PassCount;
        var failCount = Model.Instructor.FailCount;
        <text>
        bar('instMonthChart',
            @Html.Raw(JsonSerializer.Serialize(iMonthLabels)),
            @Html.Raw(JsonSerializer.Serialize(iMonthCounts)),
            'Sessions', '#6366f1');
        doughnut('instPassChart',
            ['Pass', 'Fail'],
            [@passCount, @failCount]);
        </text>
    }

    @if (Model.Role == "Training Coordinator" && Model.Coordinator != null)
    {
        var coMonthLabels = Model.Coordinator.MonthLabels;
        var coMonthCounts = Model.Coordinator.MonthEnrollmentCounts;
        var coStatusLabels = Model.Coordinator.EnrollmentLabels;
        var coStatusCounts = Model.Coordinator.EnrollmentCounts;
        var topLabels = Model.Coordinator.TopCourses.Select(x => x.CourseTitle).ToList();
        var topCounts = Model.Coordinator.TopCourses.Select(x => x.EnrollmentCount).ToList();
        var totalCollected = (double)Model.Coordinator.TotalCollected;
        var totalOutstanding = (double)Model.Coordinator.TotalOutstanding;
        <text>
        line('coEnrollChart',
            @Html.Raw(JsonSerializer.Serialize(coMonthLabels)),
            @Html.Raw(JsonSerializer.Serialize(coMonthCounts)),
            'Enrollments');
        doughnut('coStatusChart',
            @Html.Raw(JsonSerializer.Serialize(coStatusLabels)),
            @Html.Raw(JsonSerializer.Serialize(coStatusCounts)));
        bar('coTopChart',
            @Html.Raw(JsonSerializer.Serialize(topLabels)),
            @Html.Raw(JsonSerializer.Serialize(topCounts)),
            'Enrollments', '#22c55e');
        doughnut('coRevenueChart',
            ['Collected', 'Outstanding'],
            [@totalCollected, @totalOutstanding]);
        </text>
    }
})();
</script>
}
