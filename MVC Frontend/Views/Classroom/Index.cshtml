@model IEnumerable<Web_API.Models.Classroom>
@{
    ViewData["Title"] = "Classrooms";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Classrooms</h1>
        <p class="text-muted mb-0">Manage training rooms and their equipment.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Add Classroom</a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No classrooms configured yet.</p>
        <a asp-action="Create" class="btn btn-primary">Add First Classroom</a>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Building / Floor</th>
                        <th>Location</th>
                        <th class="text-center">Capacity</th>
                        <th class="text-center">Equipment</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Name</td>
                            <td>@c.Building, Floor @c.Floor</td>
                            <td>@c.Location</td>
                            <td class="text-center">@c.Capacity</td>
                            <td class="text-center">@c.ClassroomEquipments.Count</td>
                            <td class="text-center">
                                @if (c.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@c.ClassroomId"
                                   class="btn btn-sm btn-outline-primary">Details</a>
                                <a asp-action="Edit" asp-route-id="@c.ClassroomId"
                                   class="btn btn-sm btn-outline-secondary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
