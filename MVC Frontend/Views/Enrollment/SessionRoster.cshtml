@model MVC_Frontend.Models.SessionRosterViewModel
@{
    ViewData["Title"] = $"Roster – {Model.CourseTitle}";
    var isCompleted = Model.SessionStatus == "Completed";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">Session Roster</h1>
        <p class="text-muted mb-0">
            @Model.CourseTitle &mdash; @Model.SessionDate.ToString("dddd, MMMM dd, yyyy")
        </p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="badge @(isCompleted ? "bg-success" : "bg-primary") fs-6">
            @Model.SessionStatus
        </span>
        @if (isCompleted)
        {
            <a asp-controller="Assessment" asp-action="Record" asp-route-sessionId="@Model.SessionId"
               class="btn btn-success">
                Record Assessments
            </a>
        }
    </div>
</div>

@if (!Model.Trainees.Any())
{
    <div class="alert alert-light border">No trainees are enrolled in this session.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Trainee Name</th>
                            <th>Enrollment Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int row = 1;}
                        @foreach (var t in Model.Trainees)
                        {
                            <tr>
                                <td class="text-muted">@(row++)</td>
                                <td class="fw-semibold">@t.TraineeName</td>
                                <td>@StatusBadge(t.EnrollmentStatus)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small">
            @Model.Trainees.Count trainee(s) enrolled.
        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="Session" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        &larr; Back to My Sessions
    </a>
</div>

@functions {
    Microsoft.AspNetCore.Html.IHtmlContent StatusBadge(string status)
    {
        var (cls, label) = status switch
        {
            "Enrolled"  => ("bg-primary",          "Enrolled"),
            "Confirmed" => ("bg-info text-dark",    "Confirmed"),
            "Attending" => ("bg-warning text-dark", "Attending"),
            "Completed" => ("bg-success",           "Completed"),
            "Dropped"   => ("bg-secondary",         "Dropped"),
            _           => ("bg-light text-dark border", status)
        };
        return new Microsoft.AspNetCore.Html.HtmlString($"<span class='badge {cls}'>{label}</span>");
    }
}
