@model DropViewModel
@{
    ViewData["Title"] = "Drop Enrollment";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="MyEnrollments">My Enrollments</a></li>
        <li class="breadcrumb-item active">Drop</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Drop Enrollment</h5>
            </div>
            <div class="card-body">
                <p class="mb-3">Are you sure you want to drop this enrollment?</p>

                <dl class="row">
                    <dt class="col-sm-4">Course</dt>
                    <dd class="col-sm-8">@Model.CourseTitle</dd>

                    <dt class="col-sm-4">Session Date</dt>
                    <dd class="col-sm-8">@Model.SessionDate.ToString("ddd, dd MMM yyyy")</dd>

                    <dt class="col-sm-4">Current Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @StatusBadge(Model.CurrentStatus)">@Model.CurrentStatus</span>
                    </dd>
                </dl>

                <div class="alert alert-info small mb-3">
                    If this session is full, dropping your place will automatically offer it to the next trainee on the waitlist.
                </div>

                <form asp-action="Drop" method="post">
                    <input asp-for="EnrollmentId" type="hidden" />
                    <input asp-for="CourseTitle" type="hidden" />
                    <input asp-for="SessionDate" type="hidden" />
                    <input asp-for="CurrentStatus" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="DropReason" class="form-label"></label>
                        <textarea asp-for="DropReason" class="form-control" rows="2"
                                  placeholder="Optional reason..."></textarea>
                        <span asp-validation-for="DropReason" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Yes, Drop Enrollment</button>
                        <a asp-action="MyEnrollments" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    string StatusBadge(string status) => status switch
    {
        "Enrolled"  => "bg-info text-dark",
        "Confirmed" => "bg-primary",
        "Attending" => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Dropped"   => "bg-danger",
        _           => "bg-secondary"
    };
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
