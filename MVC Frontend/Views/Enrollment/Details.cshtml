@model MVC_Frontend.Models.EnrollmentDetailsViewModel
@{
    ViewData["Title"] = "Enrollment Details";
    bool isCoordinator = User.IsInRole("Training Coordinator");

    // Maps enrollment status to a Bootstrap badge colour class
    string BadgeClass(string status) => status switch
    {
        "Enrolled"  => "bg-primary",
        "Confirmed" => "bg-success",
        "Attending" => "bg-info text-dark",
        "Completed" => "bg-secondary",
        "Dropped"   => "bg-danger",
        _           => "bg-light text-dark"
    };

    // Maps assessment result to a Bootstrap badge colour class
    string ResultBadge(string result) => result switch
    {
        "Pass"    => "bg-success",
        "Fail"    => "bg-danger",
        "Pending" => "bg-warning text-dark",
        _         => "bg-light text-dark"
    };
}

<div class="mb-4">
    @if (isCoordinator)
    {
        <a asp-action="AllEnrollments" class="text-decoration-none text-muted small">← All Enrollments</a>
    }
    else
    {
        <a asp-action="MyEnrollments" class="text-decoration-none text-muted small">← My Enrollments</a>
    }
</div>

<!-- Page header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-semibold mb-1">Enrollment Details</h2>
        <span class="badge @BadgeClass(Model.StatusName) rounded-pill">@Model.StatusName</span>
    </div>

    @if (isCoordinator)
    {
        <!-- Coordinator: inline status update + create assessment shortcut -->
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 align-items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="EnrollmentId" value="@Model.EnrollmentId" />
                <select name="NewStatusId" asp-items="ViewBag.Statuses" class="form-select form-select-sm" style="width:150px;"></select>
                <input type="text" name="DropReason" class="form-control form-control-sm"
                       placeholder="Drop reason (optional)" style="width:180px;" />
                <button type="submit" class="btn btn-sm btn-outline-primary">Update Status</button>
            </form>
            <a asp-controller="Assessment" asp-action="Create"
               asp-route-enrollmentId="@Model.EnrollmentId"
               class="btn btn-sm btn-success">+ Assessment</a>
        </div>
    }
</div>

<div class="row g-4">

    <!-- Left: session info and assessments -->
    <div class="col-lg-7">

        <!-- Session Information card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="fw-semibold mb-0">Session Information</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Course</div>
                        <div class="fw-medium">@Model.CourseTitle</div>
                        <div class="small text-muted">@Model.CourseCode</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Session Date</div>
                        <div class="fw-medium">@Model.SessionDate.ToString("dddd, dd MMMM yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Time</div>
                        <div class="fw-medium">
                            @Model.StartTime.ToString("hh:mm tt") – @Model.EndTime.ToString("hh:mm tt")
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Instructor</div>
                        <div class="fw-medium">@Model.InstructorName</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Classroom</div>
                        <div class="fw-medium">@Model.ClassroomName</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Session Link</div>
                        <a asp-controller="Session" asp-action="Details"
                           asp-route-id="@Model.SessionId" class="small text-primary">
                            View session →
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Assessments card -->
        <div class="card border-0 shadow-sm">
            <div class="card-header border-0 bg-light py-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-semibold mb-0">Assessments</h6>
                <span class="badge bg-secondary rounded-pill">@Model.Assessments.Count</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.Assessments.Any())
                {
                    <div class="py-4 text-center text-muted small">No assessments recorded for this enrollment.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Instructor</th>
                                    <th>Result</th>
                                    <th>Remarks</th>
                                    @if (isCoordinator)
                                    {
                                        <th></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.Assessments)
                                {
                                    <tr>
                                        <td class="small">@a.AssessmentDate.ToString("dd MMM yyyy")</td>
                                        <td class="small">@a.InstructorName</td>
                                        <td>
                                            <span class="badge @ResultBadge(a.Result) rounded-pill">@a.Result</span>
                                        </td>
                                        <td class="small text-muted">@(a.Remarks ?? "—")</td>
                                        @if (isCoordinator)
                                        {
                                            <td>
                                                <a asp-controller="Assessment" asp-action="Details"
                                                   asp-route-id="@a.AssessmentId"
                                                   class="btn btn-sm btn-outline-secondary">View</a>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- Right: trainee and enrollment metadata -->
    <div class="col-lg-5">

        <!-- Trainee card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="fw-semibold mb-0">Trainee</h6>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <div class="small text-muted fw-medium">Name</div>
                    <div class="fw-medium">@Model.TraineeName</div>
                </div>
                <div>
                    <div class="small text-muted fw-medium">Email</div>
                    <div class="small">@Model.TraineeEmail</div>
                </div>
            </div>
        </div>

        <!-- Enrollment record card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="fw-semibold mb-0">Enrollment Record</h6>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <div class="small text-muted fw-medium">Enrollment ID</div>
                    <div class="fw-medium">#@Model.EnrollmentId</div>
                </div>
                <div class="mb-2">
                    <div class="small text-muted fw-medium">Enrolled On</div>
                    <div class="fw-medium">@Model.EnrollmentDate.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
                <div class="mb-2">
                    <div class="small text-muted fw-medium">Status Last Changed</div>
                    <div class="fw-medium">@Model.StatusChangedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.DropReason))
                {
                    <div>
                        <div class="small text-muted fw-medium">Drop Reason</div>
                        <div class="small text-danger">@Model.DropReason</div>
                    </div>
                }
            </div>
        </div>

        <!-- Trainee action: cancel if still active -->
        @if (!isCoordinator && Model.StatusName != "Dropped" && Model.StatusName != "Completed")
        {
            <a asp-action="Cancel" asp-route-id="@Model.EnrollmentId"
               class="btn btn-outline-danger w-100">Cancel Enrollment</a>
        }

    </div>

</div>
