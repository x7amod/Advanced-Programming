@model EnrollConfirmViewModel
@{
    ViewData["Title"] = "Enroll in Session";
    var session = Model.Session;
    var course = session.Course;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Course" asp-action="Details" asp-route-id="@course.CourseId">@course.CourseCode</a>
        </li>
        <li class="breadcrumb-item active">Enroll</li>
    </ol>
</nav>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h2 class="mb-1">Enroll in Session</h2>
<p class="text-muted mb-4">@course.CourseCode – @course.Title</p>

<div class="row g-4">
    <div class="col-lg-7">
        <!-- Session Details -->
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Session Details</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@session.SessionDate.ToString("dddd, dd MMMM yyyy")</dd>

                    <dt class="col-sm-4">Time</dt>
                    <dd class="col-sm-8">@session.StartTime.ToString("HH:mm") – @session.EndTime.ToString("HH:mm")</dd>

                    <dt class="col-sm-4">Classroom</dt>
                    <dd class="col-sm-8">@(session.Classroom?.ToString() ?? "TBA")</dd>

                    <dt class="col-sm-4">Instructor</dt>
                    <dd class="col-sm-8">@(session.Instructor?.Bio ?? "TBA")</dd>

                    <dt class="col-sm-4">Enrollment Fee</dt>
                    <dd class="col-sm-8 fw-semibold">BHD @course.EnrollmentFee.ToString("F2")</dd>

                    <dt class="col-sm-4">Seats</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsFull)
                        {
                            <span class="text-danger fw-semibold">Full</span>
                        }
                        else
                        {
                            <span class="text-success fw-semibold">@Model.SeatsLeft remaining</span>
                            <span class="text-muted">/ @session.MaxCapacity</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <!-- Prerequisite Check (ADV-37) -->
        @if (Model.HasPrerequisite)
        {
            <div class="card mb-3 @(Model.HasPassedPrerequisite ? "border-success" : "border-warning")">
                <div class="card-body">
                    <h5 class="card-title">Prerequisite Check</h5>
                    <p class="mb-1">
                        This course requires:
                        <strong>@Model.PrerequisiteCourseCode – @Model.PrerequisiteCourseName</strong>
                    </p>
                    @if (Model.HasPassedPrerequisite)
                    {
                        <span class="badge bg-success">Prerequisite met</span>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 mt-2">
                            <strong>Prerequisite not met.</strong>
                            You must pass <em>@Model.PrerequisiteCourseName</em> before enrolling in this course.
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-5">
        <!-- Enrollment Action Card -->
        <div class="card sticky-top" style="top: 80px;">
            <div class="card-body">
                @if (Model.IsAlreadyEnrolled)
                {
                    <div class="alert alert-info mb-3">You are already enrolled in this session.</div>
                    <a asp-action="MyEnrollments" class="btn btn-secondary w-100">My Enrollments</a>
                }
                else if (Model.IsOnWaitlist)
                {
                    <div class="alert alert-info mb-3">You are on the waitlist for this session.</div>
                    <a asp-action="MyEnrollments" class="btn btn-secondary w-100">My Enrollments</a>
                }
                else if (session.Status?.Status != "Scheduled")
                {
                    <div class="alert alert-warning mb-0">
                        Enrollment is not available. Session status: <strong>@session.Status?.Status</strong>
                    </div>
                }
                else if (!Model.HasPassedPrerequisite)
                {
                    <div class="alert alert-warning mb-0">
                        Complete the prerequisite course before enrolling.
                    </div>
                }
                else if (Model.IsFull)
                {
                    <p class="text-danger fw-semibold mb-3">This session is full.</p>
                    <form asp-action="Enroll" asp-route-sessionId="@session.SessionId" method="post">
                        <input type="hidden" name="action" value="waitlist" />
                        <button type="submit" class="btn btn-outline-warning w-100">Join Waitlist</button>
                    </form>
                }
                else
                {
                    <p class="mb-3">
                        Confirming enrollment will reserve your place. Payment can be recorded separately.
                    </p>
                    <form asp-action="Enroll" asp-route-sessionId="@session.SessionId" method="post">
                        <input type="hidden" name="action" value="enroll" />
                        <button type="submit" class="btn btn-primary w-100">Confirm Enrollment</button>
                    </form>
                }
                <a asp-controller="Course" asp-action="Details" asp-route-id="@course.CourseId"
                   class="btn btn-link w-100 mt-2">Back to Course</a>
            </div>
        </div>
    </div>
</div>
