@model IEnumerable<CourseSession>
@{
    ViewData["Title"] = "My Sessions";
    var upcoming = Model.Where(s => s.SessionDate >= DateTime.Today).OrderBy(s => s.SessionDate).ToList();
    var past     = Model.Where(s => s.SessionDate <  DateTime.Today).OrderByDescending(s => s.SessionDate).ToList();
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-1">My Sessions</h2>
        <p class="text-muted mb-0">Sessions you are assigned to instruct</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <p class="fs-5">You have no sessions assigned yet.</p>
    </div>
}
else
{
    <!-- Upcoming -->
    <h5 class="mt-3 mb-3">
        Upcoming
        <span class="badge bg-primary">@upcoming.Count</span>
    </h5>

    @if (!upcoming.Any())
    {
        <p class="text-muted small">No upcoming sessions.</p>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Course</th>
                        <th>Classroom</th>
                        <th>Enrolled</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in upcoming)
                    {
                        <tr>
                            <td class="fw-semibold">@s.SessionDate.ToString("ddd, dd MMM yyyy")</td>
                            <td class="small text-muted">@s.StartTime.ToString("HH:mm") – @s.EndTime.ToString("HH:mm")</td>
                            <td>
                                <div class="fw-semibold">@s.Course?.Title</div>
                                <div class="small text-muted">@s.Course?.SubjectArea?.Name</div>
                            </td>
                            <td class="small">@s.Classroom?.ClassroomId</td>
                            <td>
                                <span class="badge @(s.CurrentEnrollment >= s.MaxCapacity ? "bg-danger" : "bg-success")">
                                    @s.CurrentEnrollment / @s.MaxCapacity
                                </span>
                            </td>
                            <td>
                                <span class="badge @SessionStatusBadge(s.Status?.Status ?? "")">
                                    @s.Status?.Status
                                </span>
                            </td>
                            <td>
                                <a asp-controller="Enrollment" asp-action="SessionEnrollments"
                                   asp-route-sessionId="@s.SessionId"
                                   class="btn btn-sm btn-outline-secondary">
                                    View Enrollments
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Past -->
    @if (past.Any())
    {
        <details class="mb-4">
            <summary class="text-muted mb-3">Past sessions (@past.Count)</summary>
            <div class="table-responsive mt-2">
                <table class="table table-sm text-muted align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Course</th>
                            <th>Enrolled</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in past)
                        {
                            <tr>
                                <td>@s.SessionDate.ToString("dd MMM yyyy")</td>
                                <td>@s.Course?.Title</td>
                                <td>@s.CurrentEnrollment / @s.MaxCapacity</td>
                                <td>
                                    <span class="badge @SessionStatusBadge(s.Status?.Status ?? "")">
                                        @s.Status?.Status
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="Enrollment" asp-action="SessionEnrollments"
                                       asp-route-sessionId="@s.SessionId"
                                       class="btn btn-sm btn-outline-secondary btn-sm">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }
}

@functions {
    string SessionStatusBadge(string status) => status switch
    {
        "Scheduled" => "bg-primary",
        "Ongoing"   => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _           => "bg-secondary"
    };
}
