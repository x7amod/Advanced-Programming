@model List<MVC_Frontend.Models.InstructorSessionRosterViewModel>
@{
    ViewData["Title"] = "My Sessions — Enrolled Trainees";

    // Maps session status to a Bootstrap badge colour
    string SessionBadge(string s) => s switch
    {
        "Scheduled" => "bg-primary",
        "Ongoing"   => "bg-info text-dark",
        "Completed" => "bg-secondary",
        "Cancelled" => "bg-danger",
        _           => "bg-light text-dark"
    };

    // Maps enrollment status to a badge colour
    string EnrollBadge(string s) => s switch
    {
        "Enrolled"  => "bg-primary",
        "Confirmed" => "bg-success",
        "Attending" => "bg-info text-dark",
        "Completed" => "bg-secondary",
        _           => "bg-light text-dark"
    };
}

<div class="mb-4">
    <h2 class="fw-semibold mb-1">My Sessions</h2>
    <p class="text-muted mb-0">View the trainees enrolled in each of your sessions.</p>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body text-muted">
            <p class="mb-0">No sessions found for your account.</p>
        </div>
    </div>
}
else
{
    @foreach (var session in Model)
    {
        <div class="card border-0 shadow-sm mb-4">

            <!-- Session header -->
            <div class="card-header border-0 bg-light py-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <span class="fw-semibold">@session.CourseTitle</span>
                        <span class="text-muted ms-2 small">@session.CourseCode</span>
                    </div>
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <span class="small text-muted">
                            @session.SessionDate.ToString("dd MMM yyyy")
                            &nbsp;·&nbsp;
                            @session.StartTime.ToString("hh:mm tt") – @session.EndTime.ToString("hh:mm tt")
                        </span>
                        <span class="badge @SessionBadge(session.StatusName) rounded-pill">@session.StatusName</span>
                        <span class="badge bg-light text-dark border rounded-pill small">
                            @session.CurrentEnrollment / @session.MaxCapacity enrolled
                        </span>
                        <a asp-controller="Assessment" asp-action="SessionResults"
                           asp-route-sessionId="@session.SessionId"
                           class="btn btn-sm btn-outline-primary">View Results</a>
                    </div>
                </div>
            </div>

            <!-- Trainee roster table -->
            <div class="card-body p-0">
                @if (!session.Trainees.Any())
                {
                    <div class="py-3 text-center text-muted small">No trainees enrolled in this session.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Trainee</th>
                                    <th>Email</th>
                                    <th>Enrolled On</th>
                                    <th>Status</th>
                                    <th>Assessment</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in session.Trainees)
                                {
                                    <tr>
                                        <td class="fw-medium">@t.TraineeName</td>
                                        <td class="small text-muted">@t.TraineeEmail</td>
                                        <td class="small">@t.EnrollmentDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge @EnrollBadge(t.EnrollmentStatus) rounded-pill">
                                                @t.EnrollmentStatus
                                            </span>
                                        </td>
                                        <td>
                                            @if (t.HasAssessment)
                                            {
                                                <span class="badge bg-success rounded-pill small">Recorded</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill small">Pending</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="Enrollment" asp-action="Details"
                                               asp-route-id="@t.EnrollmentId"
                                               class="btn btn-sm btn-outline-secondary">Details</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    }
}
