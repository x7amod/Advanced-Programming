@model CourseSession
@{
    ViewData["Title"] = $"Enrollments – {Model.Course?.Title}";
    var allStatuses = ViewBag.AllStatuses as IEnumerable<EnrollmentStatus> ?? [];
    var activeEnrollments = Model.Enrollments.Where(e => e.EnrollmentStatus.Status != "Dropped").ToList();
    var dropped = Model.Enrollments.Where(e => e.EnrollmentStatus.Status == "Dropped").ToList();
    var waitlisted = Model.Waitlists.Where(w => w.Status == "Waiting").OrderBy(w => w.Position).ToList();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId">
                @Model.Course?.CourseCode
            </a>
        </li>
        <li class="breadcrumb-item active">Session Enrollments</li>
    </ol>
</nav>

@if (ViewBag.Success != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @ViewBag.Success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2 class="mb-1">@Model.Course?.Title</h2>
        <p class="text-muted mb-0">
            @Model.SessionDate.ToString("dddd, dd MMMM yyyy") &nbsp;·&nbsp;
            @Model.StartTime.ToString("HH:mm") – @Model.EndTime.ToString("HH:mm")
        </p>
    </div>
    <div class="text-end">
        <span class="badge @SessionStatusBadge(Model.Status?.Status ?? "") fs-6">
            @Model.Status?.Status
        </span>
        <div class="small text-muted mt-1">
            @Model.CurrentEnrollment / @Model.MaxCapacity enrolled
        </div>
    </div>
</div>

<!-- Active Enrollments -->
<h5 class="mt-4 mb-3">
    Enrollments
    <span class="badge bg-secondary">@activeEnrollments.Count</span>
</h5>

@if (!activeEnrollments.Any())
{
    <p class="text-muted">No active enrollments yet.</p>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Trainee</th>
                    <th>Enrolled On</th>
                    <th>Status</th>
                    @if (User.IsInRole("Training Coordinator"))
                    {
                        <th>Advance To</th>
                    }
                </tr>
            </thead>
            <tbody>
                @{ int row = 1; }
                @foreach (var e in activeEnrollments.OrderBy(e => e.EnrollmentDate))
                {
                    <tr>
                        <td class="text-muted small">@(row++)</td>
                        <td>
                            <div class="fw-semibold">Trainee #@e.TraineeId</div>
                        </td>
                        <td class="small">@e.EnrollmentDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            <span class="badge @StatusBadge(e.EnrollmentStatus.Status)">
                                @e.EnrollmentStatus.Status
                            </span>
                        </td>
                        @if (User.IsInRole("Training Coordinator"))
                        {
                            <td>
                                @{
                                    var nextStatuses = e.EnrollmentStatus.Status switch
                                    {
                                        "Enrolled"  => new[] { "Confirmed", "Dropped" },
                                        "Confirmed" => new[] { "Attending", "Dropped" },
                                        "Attending" => new[] { "Completed", "Dropped" },
                                        _           => Array.Empty<string>()
                                    };
                                }
                                @foreach (var ns in nextStatuses)
                                {
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="enrollmentId" value="@e.EnrollmentId" />
                                        <input type="hidden" name="newStatus" value="@ns" />
                                        <button type="submit"
                                                class="btn btn-sm @(ns == "Dropped" ? "btn-outline-danger" : "btn-outline-primary") me-1">
                                            @ns
                                        </button>
                                    </form>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Waitlist -->
@if (waitlisted.Any())
{
    <h5 class="mb-3">
        Waitlist
        <span class="badge bg-warning text-dark">@waitlisted.Count</span>
    </h5>
    <div class="table-responsive mb-4">
        <table class="table table-sm">
            <thead class="table-light">
                <tr>
                    <th>Position</th>
                    <th>Trainee</th>
                    <th>Added</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in waitlisted)
                {
                    <tr>
                        <td><span class="badge bg-warning text-dark">#@w.Position</span></td>
                        <td>Trainee #@w.TraineeId</td>
                        <td class="small text-muted">@w.AddedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Dropped -->
@if (dropped.Any())
{
    <details class="mb-4">
        <summary class="text-muted mb-2">Dropped enrollments (@dropped.Count)</summary>
        <table class="table table-sm text-muted">
            <thead>
                <tr><th>Trainee</th><th>Reason</th><th>Changed</th></tr>
            </thead>
            <tbody>
                @foreach (var e in dropped)
                {
                    <tr>
                        <td>Trainee #@e.TraineeId</td>
                        <td>@(e.DropReason ?? "—")</td>
                        <td class="small">@e.StatusChangedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </details>
}

@functions {
    string StatusBadge(string status) => status switch
    {
        "Enrolled"  => "bg-info text-dark",
        "Confirmed" => "bg-primary",
        "Attending" => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Dropped"   => "bg-danger",
        _           => "bg-secondary"
    };

    string SessionStatusBadge(string status) => status switch
    {
        "Scheduled" => "bg-primary",
        "Ongoing"   => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _           => "bg-secondary"
    };
}
