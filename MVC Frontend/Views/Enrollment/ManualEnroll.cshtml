@model MVC_Frontend.Models.ManualEnrollViewModel
@{
    ViewData["Title"] = "Manual Enrollment";
}

<div class="mb-4">
    <a asp-action="AllEnrollments" class="text-decoration-none text-muted small">← All Enrollments</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="card border-0 shadow-sm">
            <div class="card-header border-0 bg-primary bg-opacity-10 py-3">
                <h5 class="fw-semibold mb-0">Manual Enrollment</h5>
                <div class="small text-muted">Enroll a trainee into a session on their behalf</div>
            </div>
            <div class="card-body">

                <form asp-action="ManualEnroll" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                    <!-- Session picker -->
                    <div class="mb-4">
                        <label asp-for="SessionId" class="form-label fw-medium"></label>
                        <select asp-for="SessionId" asp-items="Model.Sessions"
                                class="form-select">
                            <option value="">— Select a session —</option>
                        </select>
                        <span asp-validation-for="SessionId" class="text-danger small"></span>
                        <div class="form-text">
                            Only scheduled sessions with available capacity are listed.
                        </div>
                    </div>

                    <!-- Trainee picker -->
                    <div class="mb-4">
                        <label asp-for="TraineeId" class="form-label fw-medium"></label>
                        <select asp-for="TraineeId" asp-items="Model.Trainees"
                                class="form-select">
                            <option value="">— Select a trainee —</option>
                        </select>
                        <span asp-validation-for="TraineeId" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info border-0 small mb-4">
                        The enrollment will be created with status <strong>Confirmed</strong> — no further
                        coordinator approval step is needed.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Enroll Trainee</button>
                        <a asp-action="AllEnrollments" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
