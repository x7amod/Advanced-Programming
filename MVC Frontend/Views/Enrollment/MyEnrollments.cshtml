@model IEnumerable<Enrollment>
@{
    ViewData["Title"] = "My Enrollments";
    var waitlists = ViewBag.Waitlists as IEnumerable<Waitlist> ?? [];
}

<h2 class="mb-4">My Enrollments</h2>

@if (ViewBag.Success != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @ViewBag.Success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Active & upcoming enrollments -->
<h5 class="mb-3">Enrolled Sessions</h5>
@{
    var active = Model.Where(e => e.EnrollmentStatus.Status != "Dropped" && e.EnrollmentStatus.Status != "Completed").ToList();
    var history = Model.Where(e => e.EnrollmentStatus.Status is "Dropped" or "Completed").ToList();
}

@if (!active.Any())
{
    <p class="text-muted mb-4">
        No active enrollments.
        <a asp-controller="Course" asp-action="Index">Browse courses</a>
    </p>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Course</th>
                    <th>Session Date</th>
                    <th>Time</th>
                    <th>Classroom</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in active.OrderBy(e => e.Session.SessionDate))
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">
                                <a asp-controller="Course" asp-action="Details"
                                   asp-route-id="@e.Session.CourseId">
                                    @e.Session.Course.Title
                                </a>
                            </div>
                            <div class="small text-muted">@e.Session.Course.SubjectArea?.Name</div>
                        </td>
                        <td>@e.Session.SessionDate.ToString("ddd dd MMM yyyy")</td>
                        <td class="small">@e.Session.StartTime.ToString("HH:mm") – @e.Session.EndTime.ToString("HH:mm")</td>
                        <td class="small text-muted">@(e.Session.Classroom?.ToString() ?? "—")</td>
                        <td>
                            <span class="badge @StatusBadge(e.EnrollmentStatus.Status)">
                                @e.EnrollmentStatus.Status
                            </span>
                        </td>
                        <td class="text-end">
                            @if (e.EnrollmentStatus.Status is "Enrolled" or "Confirmed")
                            {
                                <a asp-action="Drop" asp-route-enrollmentId="@e.EnrollmentId"
                                   class="btn btn-sm btn-outline-danger">Drop</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Waitlist -->
@if (waitlists.Any())
{
    <h5 class="mb-3">Waitlist</h5>
    <div class="table-responsive mb-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Course</th>
                    <th>Session Date</th>
                    <th>Position</th>
                    <th>Added</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in waitlists.OrderBy(w => w.Position))
                {
                    <tr>
                        <td class="fw-semibold">@w.Session.Course.Title</td>
                        <td>@w.Session.SessionDate.ToString("ddd dd MMM yyyy")</td>
                        <td><span class="badge bg-warning text-dark">#@w.Position</span></td>
                        <td class="small text-muted">@w.AddedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Enrollment history -->
@if (history.Any())
{
    <h5 class="mb-3 text-muted">History</h5>
    <div class="table-responsive">
        <table class="table table-sm text-muted">
            <thead class="table-light">
                <tr>
                    <th>Course</th>
                    <th>Session Date</th>
                    <th>Status</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in history.OrderByDescending(e => e.Session.SessionDate))
                {
                    <tr>
                        <td>@e.Session.Course.Title</td>
                        <td>@e.Session.SessionDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge @StatusBadge(e.EnrollmentStatus.Status)">
                                @e.EnrollmentStatus.Status
                            </span>
                        </td>
                        <td class="small">@e.DropReason</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    string StatusBadge(string status) => status switch
    {
        "Enrolled"  => "bg-info text-dark",
        "Confirmed" => "bg-primary",
        "Attending" => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Dropped"   => "bg-danger",
        _           => "bg-secondary"
    };
}
