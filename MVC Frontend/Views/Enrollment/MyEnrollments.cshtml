@model List<MVC_Frontend.Models.EnrollmentListItemViewModel>
@{
    ViewData["Title"] = "My Enrollments";

    // Helper: map status name to a Bootstrap badge colour
    string BadgeClass(string status) => status switch
    {
        "Enrolled"  => "bg-primary",
        "Confirmed" => "bg-success",
        "Attending" => "bg-info text-dark",
        "Completed" => "bg-secondary",
        "Dropped"   => "bg-danger",
        _           => "bg-light text-dark"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-semibold mb-1">My Enrollments</h2>
        <p class="text-muted mb-0">Track all your course enrollments and their current status.</p>
    </div>
    <a asp-controller="Session" asp-action="Index" class="btn btn-primary">
        Browse Sessions
    </a>
</div>

<!-- Status filter bar -->
<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label fw-medium small">Filter by Status</label>
                <select name="statusId" asp-items="ViewBag.Statuses" class="form-select form-select-sm">
                    <option value="">All statuses</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">Apply</button>
                <a asp-action="MyEnrollments" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <!-- Empty state -->
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"
                 class="text-muted mb-3">
                <rect x="6" y="4" width="12" height="17" rx="2"/>
                <path d="M9 4h6v3H9z"/><path d="M9 12l2 2 4-4"/>
            </svg>
            <h5 class="fw-medium text-muted">No enrollments found</h5>
            <p class="text-muted small mb-3">You haven't enrolled in any sessions yet.</p>
            <a asp-controller="Session" asp-action="Index" class="btn btn-primary btn-sm">
                Browse available sessions
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Session Date</th>
                            <th>Enrolled On</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@item.CourseTitle</div>
                                    <div class="small text-muted">@item.CourseCode</div>
                                </td>
                                <td>@item.SessionDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EnrollmentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge @BadgeClass(item.StatusName) rounded-pill">
                                        @item.StatusName
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(item.DropReason))
                                    {
                                        <div class="small text-muted mt-1">@item.DropReason</div>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.EnrollmentId"
                                       class="btn btn-sm btn-outline-secondary me-1">Details</a>

                                    @* Only allow cancellation for active (non-terminal) statuses *@
                                    @if (item.StatusName != "Dropped" && item.StatusName != "Completed")
                                    {
                                        <a asp-action="Cancel" asp-route-id="@item.EnrollmentId"
                                           class="btn btn-sm btn-outline-danger">Cancel</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3 text-muted small">Showing @Model.Count enrollment(s).</div>
}
