<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Training Institute</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_Frontend.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<div class="tl-shell">

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <aside class="tl-sidebar">

        <!-- Logo -->
        <div class="tl-sidebar-logo">
            <img src="~/assets/logo-mark.svg" alt="Logo" />
            <span class="tl-sidebar-logo-name">Training Institute</span>
        </div>

        @* ── Trainee nav ───────────────────── *@
        @if (User.IsInRole("Trainee"))
        {
            <div class="tl-sidebar-role">Trainee</div>
            <nav class="tl-nav">
                <a class="tl-nav-item @(ctrl=="Home"?"active":"")" asp-controller="Home" asp-action="Index">
                    @NavIcon("home") Dashboard
                </a>
                <a class="tl-nav-item @(ctrl=="Course"?"active":"")" asp-controller="Course" asp-action="Index">
                    @NavIcon("book") Browse courses
                </a>
                <a class="tl-nav-item @(ctrl=="Session"&&action=="Index"?"active":"")"
                   asp-controller="Session" asp-action="Index">
                    @NavIcon("cal") Available sessions
                </a>
                <a class="tl-nav-item @(ctrl=="Enrollment"&&action=="MyEnrollments"?"active":"")"
                   asp-controller="Enrollment" asp-action="MyEnrollments">
                    @NavIcon("clip") My enrollments
                </a>
                <a class="tl-nav-item @(ctrl=="Certification"&&action=="MyProgress"?"active":"")"
                   asp-controller="Certification" asp-action="MyProgress">
                    @NavIcon("cert") My progress
                </a>
                <a class="tl-nav-item @(ctrl=="Certification"&&action=="MyCertificates"?"active":"")"
                   asp-controller="Certification" asp-action="MyCertificates">
                    @NavIcon("award") My certificates
                </a>
            </nav>
        }

        @* ── Instructor nav ────────────────── *@
        @if (User.IsInRole("Instructor"))
        {
            <div class="tl-sidebar-role">Instructor</div>
            <nav class="tl-nav">
                <a class="tl-nav-item @(ctrl=="Home"?"active":"")" asp-controller="Home" asp-action="Index">
                    @NavIcon("home") Dashboard
                </a>
                <a class="tl-nav-item @(ctrl=="Course"?"active":"")" asp-controller="Course" asp-action="Index">
                    @NavIcon("book") Browse courses
                </a>
                <a class="tl-nav-item @(ctrl=="Session"&&action=="Index"?"active":"")"
                   asp-controller="Session" asp-action="Index">
                    @NavIcon("cal") My sessions
                </a>
                <a class="tl-nav-item @(ctrl=="Session"&&action=="Schedule"?"active":"")"
                   asp-controller="Session" asp-action="Schedule">
                    @NavIcon("bar") My schedule
                </a>
                <a class="tl-nav-item @(ctrl=="Enrollment"&&action=="MySessions"?"active":"")"
                   asp-controller="Enrollment" asp-action="MySessions">
                    @NavIcon("clip") My enrollments
                </a>
            </nav>
        }

        @* ── Training Coordinator nav ──────── *@
        @if (User.IsInRole("Training Coordinator"))
        {
            <div class="tl-sidebar-role">Coordinator</div>
            <nav class="tl-nav">
                <a class="tl-nav-item @(ctrl=="Home"?"active":"")" asp-controller="Home" asp-action="Index">
                    @NavIcon("home") Dashboard
                </a>

                <div class="tl-nav-section">Courses</div>
                <a class="tl-nav-item @(ctrl=="Course"&&action!="Create"?"active":"")"
                   asp-controller="Course" asp-action="Index">
                    @NavIcon("book") Courses
                </a>
                <a class="tl-nav-item @(ctrl=="Course"&&action=="Create"?"active":"")"
                   asp-controller="Course" asp-action="Create">
                    @NavIcon("plus") Add course
                </a>

                <div class="tl-nav-section">Sessions</div>
                <a class="tl-nav-item @(ctrl=="Session"&&action=="Index"?"active":"")"
                   asp-controller="Session" asp-action="Index">
                    @NavIcon("cal") All sessions
                </a>
                <a class="tl-nav-item @(ctrl=="Session"&&action=="Create"?"active":"")"
                   asp-controller="Session" asp-action="Create">
                    @NavIcon("plus") Schedule session
                </a>
                <a class="tl-nav-item @(ctrl=="Session"&&action=="Schedule"?"active":"")"
                   asp-controller="Session" asp-action="Schedule">
                    @NavIcon("bar") Calendar view
                </a>

                <div class="tl-nav-section">Manage</div>
                <a class="tl-nav-item @(ctrl=="Category"?"active":"")"
                   asp-controller="Category" asp-action="Index">
                    @NavIcon("tag") Categories
                </a>
                <a class="tl-nav-item @(ctrl=="SubjectArea"?"active":"")"
                   asp-controller="SubjectArea" asp-action="Index">
                    @NavIcon("bar") Subject areas
                </a>
                <a class="tl-nav-item" asp-controller="Course" asp-action="Index"
                   asp-route-showInactive="true">
                    @NavIcon("clip") All courses
                </a>

                <div class="tl-nav-section">Certification</div>
                <a class="tl-nav-item @(ctrl=="Certification"&&action!="Create"?"active":"")"
                   asp-controller="Certification" asp-action="Index">
                    @NavIcon("award") Tracks
                </a>
                <a class="tl-nav-item @(ctrl=="Certification"&&action=="Create"?"active":"")"
                   asp-controller="Certification" asp-action="Create">
                    @NavIcon("plus") New track
                </a>

                <div class="tl-nav-section">Scheduling</div>
                <a class="tl-nav-item @(ctrl=="Session"?"active":"")"
                   asp-controller="Session" asp-action="Index">
                    @NavIcon("cal") Sessions
                </a>
                <a class="tl-nav-item @(ctrl=="UserManagement"?"active":"")"
                   asp-controller="UserManagement" asp-action="Index">
                    @NavIcon("user") Users
                </a>
            </nav>
        }

        @* ── Public nav (not logged in) ────── *@
        @if (User.Identity == null || !User.Identity.IsAuthenticated)
        {
            <nav class="tl-nav mt-2">
                <a class="tl-nav-item @(ctrl=="Home"?"active":"")" asp-controller="Home" asp-action="Index">
                    @NavIcon("home") Home
                </a>
                <a class="tl-nav-item @(ctrl=="Course"?"active":"")" asp-controller="Course" asp-action="Index">
                    @NavIcon("book") Browse courses
                </a>
            </nav>
        }

        <!-- Bottom: sign out -->
        <div class="tl-sidebar-bottom">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <!-- Abdullah wires this: asp-controller="Account" asp-action="Logout" -->
                    <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="tl-signout" style="background:none;border:none;width:100%;text-align:left;cursor:pointer;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 4h5v16h-5" />
                                <path d="m10 8-4 4 4 4" />
                                <path d="M6 12h11" />
                            </svg>
                            Sign out
                        </button>
                    </form>
            }
        </div>

    </aside>

    <!-- Sidebar overlay (mobile tap-to-close backdrop) -->
    <div class="tl-sidebar-overlay" id="tl-sidebar-overlay"></div>

    <!-- ══════════════ MAIN ══════════════ -->
    <div class="tl-main">

        <!-- ── Topbar ── -->
        <header class="tl-topbar">

            <!-- Hamburger (mobile only) -->
            <button class="tl-hamburger" id="tl-hamburger" type="button" title="Open menu" aria-label="Open menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>

            <!-- Page title -->
            <div class="tl-topbar-title">@(ViewData["Title"] ?? "Training Institute")</div>

            <!-- Search -->
            <div class="tl-search">
                <svg class="tl-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="6"/><path d="m20 20-3.5-3.5"/>
                </svg>
                <input class="tl-search-input" type="text" placeholder="Search courses, sessions…" />
            </div>

            <!-- Right actions -->
            <div class="tl-topbar-actions">

                <!-- Notification bell -->
                <button class="tl-icon-btn" type="button" title="Notifications">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 16h12l-1.4-2V11a4.6 4.6 0 0 0-9.2 0v3z"/><path d="M10 19a2 2 0 0 0 4 0"/>
                    </svg>
                    <span class="tl-notif-dot"></span>
                </button>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    @* User profile chip — Abdullah wires the name *@
                    var uName    = User.Identity.Name ?? "User";
                    var uInitials = uName.Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString().ToUpper() : "").Aggregate("", (a, b) => a + b);
                    if (uInitials.Length == 0) uInitials = "U";
                    var uRole = User.IsInRole("Training Coordinator") ? "Training Coordinator"
                              : User.IsInRole("Instructor")           ? "Instructor"
                              : User.IsInRole("Trainee")              ? "Trainee"
                              : "";
                    <!-- Abdullah wires this to profile page -->
                    <button class="tl-user-btn" type="button">
                        <div class="tl-avatar">@uInitials</div>
                        <div class="tl-user-info">
                            <span class="tl-user-name">@uName</span>
                            <span class="tl-user-role">@uRole</span>
                        </div>
                    </button>
                }
                else
                {
                    @* Auth buttons — Abdullah wires asp-controller="Account" *@
                    <a class="tl-btn-ghost" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="tl-btn-primary" asp-controller="Account" asp-action="Register">Sign up</a>
                }
            </div>

        </header>

        <!-- ── Content ── -->
        <main class="tl-content" role="main">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show mb-4">
                    @TempData["Info"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>

    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
(function () {
    var btn     = document.getElementById('tl-hamburger');
    var sidebar = document.querySelector('.tl-sidebar');
    var overlay = document.getElementById('tl-sidebar-overlay');
    if (!btn) return;
    function open()  { sidebar.classList.add('open');    overlay.classList.add('visible'); }
    function close() { sidebar.classList.remove('open'); overlay.classList.remove('visible'); }
    btn.addEventListener('click', function () { sidebar.classList.contains('open') ? close() : open(); });
    overlay.addEventListener('click', close);
})();
</script>
</body>
</html>

@* ── Inline icon helper ─────────────────────────────────────────── *@
@functions {
    Microsoft.AspNetCore.Html.IHtmlContent NavIcon(string name)
    {
        var paths = name switch
        {
            "home"  => "<path d='M3 12 12 4l9 8'/><path d='M5 10v9h14v-9'/>",
            "book"  => "<path d='M4 5h12a3 3 0 0 1 3 3v11H7a3 3 0 0 1-3-3z'/><path d='M4 5v11'/>",
            "cal"   => "<rect x='4' y='5' width='16' height='15' rx='2'/><path d='M8 3v4M16 3v4M4 10h16'/>",
            "clip"  => "<rect x='6' y='4' width='12' height='17' rx='2'/><path d='M9 4h6v3H9z'/><path d='M9 12l2 2 4-4'/>",
            "bar"   => "<path d='M4 20V10M10 20V4M16 20v-7M22 20H2'/>",
            "plus"  => "<path d='M12 5v14M5 12h14'/>",
            "tag"   => "<path d='M4 4h7l9 9-7 7-9-9V4z'/><circle cx='8.5' cy='8.5' r='1.5'/>",
            "user"  => "<circle cx='12' cy='8' r='4'/><path d='M4 21a8 8 0 0 1 16 0'/>",
            "cert"  => "<path d='M12 2l3 6.5 7 1-5 4.9 1.2 7L12 18l-6.2 3.4 1.2-7L2 9.5l7-1z'/>",
            "award" => "<circle cx='12' cy='9' r='6'/><path d='m9.2 14.8-1.7 5.2 4.5-2.7 4.5 2.7-1.7-5.2'/>",
            _       => "<circle cx='12' cy='12' r='4'/>"
        };
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'>{paths}</svg>"
        );
    }
}
