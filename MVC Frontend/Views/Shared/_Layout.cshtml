<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Training Institute</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_Frontend.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Navbar ─────────────────────────────────────────────── -->
    <header>
        <nav class="navbar navbar-expand-lg site-navbar">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">&#127891;</span>
                    Training Institute
                </a>

                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    <!-- Left nav links -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a>
                        </li>

                        @if (User.IsInRole("Trainee"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enrollment" asp-action="MyEnrollments">My Enrollments</a>
                            </li>
                        }

                        @if (User.IsInRole("Training Coordinator"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Manage
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Course" asp-action="Index"
                                           asp-route-showInactive="true">All Courses</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Category" asp-action="Index">Categories</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="SubjectArea" asp-action="Index">Subject Areas</a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <!-- Right: user info / auth -->
                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                @{
                                    var displayName = User.Identity.Name ?? "User";
                                    var initials = displayName.Length > 0
                                        ? displayName[0].ToString().ToUpper()
                                        : "U";
                                }
                                <span class="user-chip">
                                    <span class="avatar">@initials</span>
                                    @displayName
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- ── Main Content ───────────────────────────────────────── -->
    <main role="main">
        <div class="container page-container">
            @if (TempData["GlobalSuccess"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3">
                    @TempData["GlobalSuccess"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["GlobalError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3">
                    @TempData["GlobalError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <footer class="site-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 py-3">
            <span class="footer-brand">Training Institute</span>
            <span>&copy; @DateTime.Now.Year &nbsp;·&nbsp; All rights reserved</span>
            <span>
                Bahrain Polytechnic &nbsp;·&nbsp; IT8118 Advanced Programming
            </span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
