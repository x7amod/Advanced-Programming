<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Training Institute</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_Frontend.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<div class="tl-shell">

    <!-- ── Sidebar ──────────────────────────────────────────────── -->
    <aside class="tl-sidebar">

        <!-- Logo -->
        <div class="tl-sidebar-logo">
            <img src="~/assets/logo-mark.svg" alt="Logo" />
            <span class="tl-sidebar-logo-name">Training Institute</span>
        </div>

        @* ── Trainee nav ───────────────────────────────────────── *@
        @if (User.IsInRole("Trainee"))
        {
            <div class="tl-sidebar-role">Trainee</div>
            <nav class="tl-nav">
                <a class="tl-nav-item @(ctrl=="Home" ? "active":"")"
                   asp-controller="Home" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 12 4l9 8"/><path d="M5 10v9h14v-9"/>
                    </svg>
                    Dashboard
                </a>
                <a class="tl-nav-item @(ctrl=="Course" ? "active":"")"
                   asp-controller="Course" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 5h12a3 3 0 0 1 3 3v11H7a3 3 0 0 1-3-3z"/><path d="M4 5v11"/>
                    </svg>
                    Browse courses
                </a>
                <a class="tl-nav-item @(ctrl=="Enrollment" && action=="MyEnrollments" ? "active":"")"
                   asp-controller="Enrollment" asp-action="MyEnrollments">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="5" width="16" height="15" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/>
                    </svg>
                    My enrollments
                </a>
            </nav>
        }

        @* ── Instructor nav ────────────────────────────────────── *@
        @if (User.IsInRole("Instructor"))
        {
            <div class="tl-sidebar-role">Instructor</div>
            <nav class="tl-nav">
                <a class="tl-nav-item @(ctrl=="Home" ? "active":"")"
                   asp-controller="Home" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 12 4l9 8"/><path d="M5 10v9h14v-9"/>
                    </svg>
                    Dashboard
                </a>
                <a class="tl-nav-item @(ctrl=="Course" ? "active":"")"
                   asp-controller="Course" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 5h12a3 3 0 0 1 3 3v11H7a3 3 0 0 1-3-3z"/><path d="M4 5v11"/>
                    </svg>
                    Browse courses
                </a>
                <a class="tl-nav-item @(ctrl=="Enrollment" && action=="MySessions" ? "active":"")"
                   asp-controller="Enrollment" asp-action="MySessions">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="5" width="16" height="15" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/>
                    </svg>
                    My sessions
                </a>
            </nav>
        }

        @* ── Training Coordinator nav ──────────────────────────── *@
        @if (User.IsInRole("Training Coordinator"))
        {
            <div class="tl-sidebar-role">Coordinator</div>
            <nav class="tl-nav">
                <a class="tl-nav-item @(ctrl=="Home" ? "active":"")"
                   asp-controller="Home" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 12 4l9 8"/><path d="M5 10v9h14v-9"/>
                    </svg>
                    Dashboard
                </a>

                <div class="tl-nav-section">Courses</div>
                <a class="tl-nav-item @(ctrl=="Course" && action!="Create" ? "active":"")"
                   asp-controller="Course" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 5h12a3 3 0 0 1 3 3v11H7a3 3 0 0 1-3-3z"/><path d="M4 5v11"/>
                    </svg>
                    Courses
                </a>
                <a class="tl-nav-item @(ctrl=="Course" && action=="Create" ? "active":"")"
                   asp-controller="Course" asp-action="Create">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                    Add course
                </a>

                <div class="tl-nav-section">Manage</div>
                <a class="tl-nav-item @(ctrl=="Category" ? "active":"")"
                   asp-controller="Category" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="9" r="3.5"/><path d="M2.5 19a6.5 6.5 0 0 1 13 0"/><circle cx="17" cy="10" r="2.8"/><path d="M21.5 18a4.5 4.5 0 0 0-6-3.4"/>
                    </svg>
                    Categories
                </a>
                <a class="tl-nav-item @(ctrl=="SubjectArea" ? "active":"")"
                   asp-controller="SubjectArea" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/>
                    </svg>
                    Subject areas
                </a>
                <a class="tl-nav-item @(ctrl=="Enrollment" ? "active":"")"
                   asp-controller="Course" asp-action="Index"
                   asp-route-showInactive="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4h6v3H9z"/><path d="M9 12l2 2 4-4"/>
                    </svg>
                    All courses
                </a>
            </nav>
        }

        @* ── Unauthenticated: show public nav ─────────────────── *@
        @if (!User.Identity!.IsAuthenticated)
        {
            <nav class="tl-nav mt-2">
                <a class="tl-nav-item @(ctrl=="Home" ? "active":"")"
                   asp-controller="Home" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 12 4l9 8"/><path d="M5 10v9h14v-9"/>
                    </svg>
                    Home
                </a>
                <a class="tl-nav-item @(ctrl=="Course" ? "active":"")"
                   asp-controller="Course" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 5h12a3 3 0 0 1 3 3v11H7a3 3 0 0 1-3-3z"/><path d="M4 5v11"/>
                    </svg>
                    Browse courses
                </a>
            </nav>
        }

        <!-- Abdullah's sign-out section goes here -->
        <div class="tl-sidebar-bottom">
            {{-- Abdullah: sign-out button --}}
        </div>

    </aside>

    <!-- ── Main area ─────────────────────────────────────────────── -->
    <div class="tl-main">

        <!-- Topbar -->
        <header class="tl-topbar">
            <div class="tl-topbar-title">@(ViewData["Title"] ?? "Training Institute")</div>
            {{-- Abdullah: search, notifications bell, user avatar --}}
        </header>

        <!-- Content -->
        <main class="tl-content" role="main">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>

    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
