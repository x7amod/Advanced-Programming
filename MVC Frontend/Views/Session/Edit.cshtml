@model SessionFormViewModel
@{
    ViewData["Title"] = "Edit Session";
    var sessionStatus = ViewBag.SessionStatus as string ?? "Scheduled";
    bool isOngoing   = sessionStatus == "Ongoing";
    bool isScheduled = sessionStatus == "Scheduled" || sessionStatus == "Cancelled";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Sessions</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.SessionId">Session #@Model.SessionId</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Edit Session #@Model.SessionId</h2>
    <span class="badge fs-6
        @(sessionStatus == "Scheduled" ? "bg-primary" :
          sessionStatus == "Ongoing"   ? "bg-success" :
          sessionStatus == "Cancelled" ? "bg-danger"  : "bg-secondary")">
        @sessionStatus
    </span>
</div>

@if (isOngoing)
{
    <div class="alert alert-warning d-flex align-items-start gap-2 mb-4">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-1">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <div>
            <strong>Session is Ongoing.</strong>
            Only the <strong>classroom</strong> can be changed while the session is in progress.
            Instructor, date, time, capacity, and status are locked.
        </div>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Edit" method="post">
            <input asp-for="SessionId" type="hidden" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
            }

            <!-- Course & Instructor -->
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">
                        Course & Instructor
                        @if (isOngoing) { <span class="badge bg-secondary ms-2 fw-normal" style="font-size:.7rem;">locked</span> }
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CourseId" class="form-label"></label>
                            <select asp-for="CourseId" asp-items="Model.Courses" class="form-select" disabled="@isOngoing">
                                <option value="">— Select course —</option>
                            </select>
                            @if (isOngoing) { <input type="hidden" asp-for="CourseId" /> }
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="InstructorId" class="form-label"></label>
                            <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select" disabled="@isOngoing">
                                <option value="">— Select instructor —</option>
                            </select>
                            @if (isOngoing) { <input type="hidden" asp-for="InstructorId" /> }
                            <span asp-validation-for="InstructorId" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Schedule -->
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">
                        Schedule
                        @if (isOngoing) { <span class="badge bg-secondary ms-2 fw-normal" style="font-size:.7rem;">locked</span> }
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="SessionDate" class="form-label"></label>
                            <input asp-for="SessionDate" type="date" class="form-control" disabled="@isOngoing" />
                            @if (isOngoing) { <input type="hidden" asp-for="SessionDate" /> }
                            <span asp-validation-for="SessionDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartTime" class="form-label"></label>
                            <input asp-for="StartTime" type="time" class="form-control" disabled="@isOngoing" />
                            @if (isOngoing) { <input type="hidden" asp-for="StartTime" /> }
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndTime" class="form-label"></label>
                            <input asp-for="EndTime" type="time" class="form-control" disabled="@isOngoing" />
                            @if (isOngoing) { <input type="hidden" asp-for="EndTime" /> }
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                            <div class="form-text small" id="durationHint"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Classroom & Capacity -->
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Classroom & Capacity</h5>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="ClassroomId" class="form-label"></label>
                            <select asp-for="ClassroomId" asp-items="Model.Classrooms" class="form-select">
                                <option value="">— Select classroom —</option>
                            </select>
                            <span asp-validation-for="ClassroomId" class="text-danger small"></span>
                            @if (isOngoing)
                            {
                                <div class="form-text text-success small">✓ This field can be changed.</div>
                            }
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxCapacity" class="form-label"></label>
                            <input asp-for="MaxCapacity" type="number" class="form-control" min="1" max="1000" disabled="@isOngoing" />
                            @if (isOngoing) { <input type="hidden" asp-for="MaxCapacity" /> }
                            <span asp-validation-for="MaxCapacity" class="text-danger small"></span>
                            @if (!isOngoing)
                            {
                                <div class="form-text small">Cannot be reduced below current enrollment count.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status -->
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">
                        Status
                        @if (isOngoing) { <span class="badge bg-secondary ms-2 fw-normal" style="font-size:.7rem;">locked</span> }
                    </h5>
                    <div class="col-md-4">
                        <label asp-for="StatusId" class="form-label"></label>
                        <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select" disabled="@isOngoing"></select>
                        @if (isOngoing) { <input type="hidden" asp-for="StatusId" /> }
                        <span asp-validation-for="StatusId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    @(isOngoing ? "Update Classroom" : "Save Changes")
                </button>
                <a asp-action="Details" asp-route-id="@Model.SessionId" class="btn btn-secondary">Cancel</a>
                @if (isScheduled)
                {
                    <a asp-action="Delete" asp-route-id="@Model.SessionId" class="btn btn-outline-danger ms-auto">Delete Session</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @if (!isOngoing)
    {
        <script>
        (function () {
            var startInput = document.querySelector('input[name="StartTime"]:not([type="hidden"])');
            var endInput   = document.querySelector('input[name="EndTime"]:not([type="hidden"])');
            var hint       = document.getElementById('durationHint');
            if (!startInput || !endInput) return;

            function updateDuration() {
                if (!startInput.value || !endInput.value) { hint.textContent = ''; return; }
                var [sh, sm] = startInput.value.split(':').map(Number);
                var [eh, em] = endInput.value.split(':').map(Number);
                var mins = (eh * 60 + em) - (sh * 60 + sm);
                if (mins <= 0) {
                    hint.textContent = '⚠ End time must be after start time.';
                    hint.className = 'form-text small text-danger';
                } else {
                    var h = Math.floor(mins / 60), m = mins % 60;
                    hint.textContent = 'Duration: ' + (h > 0 ? h + 'h ' : '') + (m > 0 ? m + 'min' : '');
                    hint.className = 'form-text small text-muted';
                }
            }

            startInput.addEventListener('change', updateDuration);
            endInput.addEventListener('change', updateDuration);
            updateDuration();
        })();
        </script>
    }
}
