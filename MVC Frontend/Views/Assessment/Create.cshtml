@model MVC_Frontend.Models.AssessmentFormViewModel
@{
    ViewData["Title"] = "Create Assessment";
    bool hasPreselectedEnrollment = Model.EnrollmentId > 0;
}

<div class="mb-4">
    <a asp-action="AllAssessments" class="text-decoration-none text-muted small">← All Assessments</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="card border-0 shadow-sm">
            <div class="card-header border-0 bg-primary bg-opacity-10 py-3">
                <h5 class="fw-semibold mb-0">Create Assessment</h5>
                <div class="small text-muted">Record the result for a trainee's enrollment</div>
            </div>
            <div class="card-body">

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                    @if (hasPreselectedEnrollment)
                    {
                        <!-- When arriving from an enrollment detail page, the enrollment is fixed -->
                        <input type="hidden" asp-for="EnrollmentId" />

                        <!-- Read-only context block so coordinator knows who this is for -->
                        <div class="bg-light rounded p-3 mb-4">
                            <div class="small text-muted fw-medium mb-1">For Enrollment</div>
                            <div class="fw-semibold">@Model.TraineeName</div>
                            <div class="small text-muted">
                                @Model.CourseTitle (@Model.CourseCode) &nbsp;·&nbsp;
                                @Model.SessionDate.ToString("dd MMM yyyy")
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Generic create: coordinator picks the enrollment -->
                        <div class="mb-4">
                            <label asp-for="EnrollmentId" class="form-label fw-medium"></label>
                            <select asp-for="EnrollmentId" asp-items="Model.Enrollments" class="form-select">
                                <option value="">— Select an enrollment —</option>
                            </select>
                            <span asp-validation-for="EnrollmentId" class="text-danger small"></span>
                            <div class="form-text">Only enrollments without an existing assessment are listed.</div>
                        </div>
                    }

                    <!-- Instructor -->
                    <div class="mb-4">
                        <label asp-for="InstructorId" class="form-label fw-medium"></label>
                        <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select">
                            <option value="">— Select an instructor —</option>
                        </select>
                        <span asp-validation-for="InstructorId" class="text-danger small"></span>
                    </div>

                    <!-- Result -->
                    <div class="mb-4">
                        <label asp-for="Result" class="form-label fw-medium"></label>
                        <select asp-for="Result" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Pass">Pass</option>
                            <option value="Fail">Fail</option>
                        </select>
                        <span asp-validation-for="Result" class="text-danger small"></span>
                    </div>

                    <!-- Assessment Date -->
                    <div class="mb-4">
                        <label asp-for="AssessmentDate" class="form-label fw-medium"></label>
                        <input asp-for="AssessmentDate" type="date" class="form-control"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="AssessmentDate" class="text-danger small"></span>
                    </div>

                    <!-- Remarks -->
                    <div class="mb-4">
                        <label asp-for="Remarks" class="form-label fw-medium"></label>
                        <textarea asp-for="Remarks" class="form-control" rows="3"
                                  placeholder="Optional notes about this assessment"></textarea>
                        <span asp-validation-for="Remarks" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Save Assessment</button>
                        <a asp-action="AllAssessments" class="btn btn-outline-secondary">Cancel</a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
