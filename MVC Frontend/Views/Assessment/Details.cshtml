@model MVC_Frontend.Models.AssessmentDetailsViewModel
@{
    ViewData["Title"] = "Assessment Details";
    bool isCoordinator = User.IsInRole("Training Coordinator");

    string ResultBadge(string result) => result switch
    {
        "Pass"    => "bg-success",
        "Fail"    => "bg-danger",
        "Pending" => "bg-warning text-dark",
        _         => "bg-light text-dark"
    };
}

<!-- Back link depends on the viewer's role -->
<div class="mb-4">
    @if (isCoordinator)
    {
        <a asp-action="AllAssessments" class="text-decoration-none text-muted small">← All Assessments</a>
    }
    else if (User.IsInRole("Trainee"))
    {
        <a asp-action="MyAssessments" class="text-decoration-none text-muted small">← My Assessments</a>
    }
    else
    {
        <a asp-controller="Enrollment" asp-action="MySessions"
           class="text-decoration-none text-muted small">← My Sessions</a>
    }
</div>

<!-- Header row with result badge and coordinator actions -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-semibold mb-1">Assessment Details</h2>
        <span class="badge @ResultBadge(Model.Result) rounded-pill fs-6">@Model.Result</span>
    </div>
    @if (isCoordinator)
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.AssessmentId"
               class="btn btn-outline-primary btn-sm">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.AssessmentId"
               class="btn btn-outline-danger btn-sm">Delete</a>
        </div>
    }
</div>

<div class="row g-4">

    <!-- Left: assessment record -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="fw-semibold mb-0">Assessment Record</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Course</div>
                        <div class="fw-medium">@Model.CourseTitle</div>
                        <div class="small text-muted">@Model.CourseCode</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Session Date</div>
                        <div class="fw-medium">@Model.SessionDate.ToString("dddd, dd MMMM yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Instructor</div>
                        <div class="fw-medium">@Model.InstructorName</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Assessment Date</div>
                        <div class="fw-medium">@Model.AssessmentDate.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Result</div>
                        <span class="badge @ResultBadge(Model.Result) rounded-pill">@Model.Result</span>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-muted fw-medium">Record Created</div>
                        <div class="small">@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Remarks))
                    {
                        <div class="col-12">
                            <div class="small text-muted fw-medium">Remarks</div>
                            <div class="p-3 bg-light rounded small mt-1">@Model.Remarks</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Right: trainee and enrollment link -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="fw-semibold mb-0">Trainee</h6>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <div class="small text-muted fw-medium">Name</div>
                    <div class="fw-medium">@Model.TraineeName</div>
                </div>
                <div class="mb-2">
                    <div class="small text-muted fw-medium">Email</div>
                    <div class="small">@Model.TraineeEmail</div>
                </div>
                <div>
                    <div class="small text-muted fw-medium">Enrollment Status</div>
                    <span class="badge bg-secondary rounded-pill small">@Model.EnrollmentStatus</span>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="fw-semibold mb-0">Linked Enrollment</h6>
            </div>
            <div class="card-body">
                <a asp-controller="Enrollment" asp-action="Details"
                   asp-route-id="@Model.EnrollmentId"
                   class="btn btn-outline-secondary w-100 btn-sm">
                    View Enrollment #@Model.EnrollmentId →
                </a>
            </div>
        </div>
    </div>

</div>
