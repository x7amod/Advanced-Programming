@model List<MVC_Frontend.Models.AssessmentListItemViewModel>
@{
    ViewData["Title"] = "My Assessments";

    string ResultBadge(string result) => result switch
    {
        "Pass"    => "bg-success",
        "Fail"    => "bg-danger",
        "Pending" => "bg-warning text-dark",
        _         => "bg-light text-dark"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-semibold mb-1">My Assessments</h2>
        <p class="text-muted mb-0">Review your assessment results for all completed sessions.</p>
    </div>
</div>

<!-- Result filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label fw-medium small">Filter by Result</label>
                <select name="result" class="form-select form-select-sm">
                    <option value="" selected="@(ViewBag.SelectedResult == null)">All results</option>
                    <option value="Pass" selected="@(ViewBag.SelectedResult == "Pass")">Pass</option>
                    <option value="Fail" selected="@(ViewBag.SelectedResult == "Fail")">Fail</option>
                    <option value="Pending" selected="@(ViewBag.SelectedResult == "Pending")">Pending</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">Apply</button>
                <a asp-action="MyAssessments" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="text-muted mb-3">
                <rect x="4" y="5" width="16" height="15" rx="2"/>
                <path d="M8 3v4M16 3v4M4 10h16"/>
                <path d="M9 15l2 2 4-4"/>
            </svg>
            <h5 class="fw-medium text-muted">No assessments found</h5>
            <p class="text-muted small mb-0">Assessments will appear here once an instructor records them.</p>
        </div>
    </div>
}
else
{
    <!-- Summary chips -->
    <div class="d-flex gap-2 flex-wrap mb-3">
        <span class="badge bg-success rounded-pill px-3 py-2">
            Pass: @Model.Count(a => a.Result == "Pass")
        </span>
        <span class="badge bg-danger rounded-pill px-3 py-2">
            Fail: @Model.Count(a => a.Result == "Fail")
        </span>
        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
            Pending: @Model.Count(a => a.Result == "Pending")
        </span>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Session Date</th>
                            <th>Instructor</th>
                            <th>Assessment Date</th>
                            <th>Result</th>
                            <th>Remarks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@item.CourseTitle</div>
                                    <div class="small text-muted">@item.CourseCode</div>
                                </td>
                                <td class="small">@item.SessionDate.ToString("dd MMM yyyy")</td>
                                <td class="small">@item.InstructorName</td>
                                <td class="small">@item.AssessmentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge @ResultBadge(item.Result) rounded-pill">
                                        @item.Result
                                    </span>
                                </td>
                                <td class="small text-muted">@(item.Remarks ?? "—")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.AssessmentId"
                                       class="btn btn-sm btn-outline-secondary">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3 text-muted small">Showing @Model.Count assessment(s).</div>
}
