@model MVC_Frontend.Models.AllAssessmentsViewModel
@{
    ViewData["Title"] = "All Assessments";

    string ResultBadge(string result) => result switch
    {
        "Pass"    => "bg-success",
        "Fail"    => "bg-danger",
        "Pending" => "bg-warning text-dark",
        _         => "bg-light text-dark"
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-semibold mb-1">All Assessments</h2>
        <p class="text-muted mb-0">Create, update, and track assessment records across all sessions.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ New Assessment</a>
</div>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label fw-medium small">Session</label>
                <select name="sessionId" asp-items="Model.Sessions" class="form-select form-select-sm">
                    <option value="">All sessions</option>
                </select>
            </div>
            <div class="col-sm-3">
                <label class="form-label fw-medium small">Instructor</label>
                <select name="instructorId" asp-items="Model.Instructors" class="form-select form-select-sm">
                    <option value="">All instructors</option>
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label fw-medium small">Result</label>
                <select name="result" class="form-select form-select-sm">
                    <option value="">All results</option>
                    <option value="Pass"    selected="@(Model.FilterResult == "Pass")">Pass</option>
                    <option value="Fail"    selected="@(Model.FilterResult == "Fail")">Fail</option>
                    <option value="Pending" selected="@(Model.FilterResult == "Pending")">Pending</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                <a asp-action="AllAssessments" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Summary chips -->
<div class="d-flex gap-2 flex-wrap mb-3">
    <span class="badge bg-light text-dark border px-3 py-2">
        Total: <strong>@Model.Assessments.Count</strong>
    </span>
    <span class="badge bg-success rounded-pill px-3 py-2">
        Pass: @Model.Assessments.Count(a => a.Result == "Pass")
    </span>
    <span class="badge bg-danger rounded-pill px-3 py-2">
        Fail: @Model.Assessments.Count(a => a.Result == "Fail")
    </span>
    <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
        Pending: @Model.Assessments.Count(a => a.Result == "Pending")
    </span>
</div>

@if (!Model.Assessments.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body text-muted">
            <p class="mb-2">No assessments match the selected filters.</p>
            <a asp-action="Create" class="btn btn-sm btn-primary">Create the first assessment</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Trainee</th>
                            <th>Course</th>
                            <th>Session Date</th>
                            <th>Instructor</th>
                            <th>Date</th>
                            <th>Result</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Assessments)
                        {
                            <tr>
                                <td class="text-muted small">@item.AssessmentId</td>
                                <td class="fw-medium">@item.TraineeName</td>
                                <td>
                                    <div class="fw-medium">@item.CourseTitle</div>
                                    <div class="small text-muted">@item.CourseCode</div>
                                </td>
                                <td class="small">@item.SessionDate.ToString("dd MMM yyyy")</td>
                                <td class="small">@item.InstructorName</td>
                                <td class="small">@item.AssessmentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge @ResultBadge(item.Result) rounded-pill">
                                        @item.Result
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.AssessmentId"
                                       class="btn btn-sm btn-outline-secondary me-1">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.AssessmentId"
                                       class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.AssessmentId"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
