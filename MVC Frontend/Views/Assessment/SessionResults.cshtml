@model MVC_Frontend.Models.SessionResultsViewModel
@{
    ViewData["Title"] = "Session Results";

    string ResultBadge(string result) => result switch
    {
        "Pass"    => "bg-success",
        "Fail"    => "bg-danger",
        "Pending" => "bg-warning text-dark",
        _         => "bg-light text-dark"
    };

    string SessionBadge(string s) => s switch
    {
        "Scheduled" => "bg-primary",
        "Ongoing"   => "bg-info text-dark",
        "Completed" => "bg-secondary",
        "Cancelled" => "bg-danger",
        _           => "bg-light text-dark"
    };
}

<div class="mb-4">
    <a asp-controller="Enrollment" asp-action="MySessions"
       class="text-decoration-none text-muted small">← My Sessions</a>
</div>

<!-- Session header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-semibold mb-1">Session Results</h2>
        <div class="text-muted small">
            <span class="fw-medium">@Model.CourseTitle</span>
            <span class="ms-1">(@Model.CourseCode)</span>
            <span class="mx-2">·</span>
            @Model.SessionDate.ToString("dddd, dd MMMM yyyy")
        </div>
    </div>
    <span class="badge @SessionBadge(Model.SessionStatus) rounded-pill">@Model.SessionStatus</span>
</div>

<!-- Summary banner -->
<div class="row g-3 mb-4">
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold">@Model.TotalEnrolled</div>
            <div class="small text-muted">Total Enrolled</div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-success border-3">
            <div class="fs-4 fw-bold text-success">@Model.PassCount</div>
            <div class="small text-muted">Passed</div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-danger border-3">
            <div class="fs-4 fw-bold text-danger">@Model.FailCount</div>
            <div class="small text-muted">Failed</div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-warning border-3">
            <div class="fs-4 fw-bold text-warning">@Model.PendingCount</div>
            <div class="small text-muted">Pending</div>
        </div>
    </div>
</div>

@if (!Model.Results.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body text-muted">
            <p class="mb-0">No trainees are enrolled in this session.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Trainee</th>
                            <th>Enrollment Status</th>
                            <th>Assessment Date</th>
                            <th>Result</th>
                            <th>Remarks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Results)
                        {
                            <tr>
                                <td class="fw-medium">@row.TraineeName</td>
                                <td>
                                    <span class="badge bg-secondary rounded-pill small">
                                        @row.EnrollmentStatus
                                    </span>
                                </td>
                                <td class="small">
                                    @(row.AssessmentDate.HasValue
                                        ? row.AssessmentDate.Value.ToString("dd MMM yyyy")
                                        : "—")
                                </td>
                                <td>
                                    <span class="badge @ResultBadge(row.Result) rounded-pill">
                                        @row.Result
                                    </span>
                                </td>
                                <td class="small text-muted">@(row.Remarks ?? "—")</td>
                                <td class="text-end">
                                    @if (row.AssessmentId.HasValue)
                                    {
                                        <a asp-controller="Assessment" asp-action="Details"
                                           asp-route-id="@row.AssessmentId"
                                           class="btn btn-sm btn-outline-secondary">View Assessment</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No assessment</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
