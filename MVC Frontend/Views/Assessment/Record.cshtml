@model MVC_Frontend.Models.RecordAssessmentViewModel
@{
    ViewData["Title"] = "Record Assessments";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">Record Assessments</h1>
        <p class="text-muted mb-0">
            @Model.CourseTitle &mdash; @Model.SessionDate.ToString("dddd, MMMM dd, yyyy")
        </p>
    </div>
    <a asp-controller="Enrollment" asp-action="SessionRoster"
       asp-route-sessionId="@Model.SessionId"
       class="btn btn-outline-secondary btn-sm">&larr; Back to Roster</a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All"></div>
    </div>
}

@if (!Model.Trainees.Any())
{
    <div class="alert alert-info">
        No eligible trainees found. Only trainees with <strong>Attending</strong> status
        and no existing assessment are shown here.
    </div>
}
else
{
    <div class="alert alert-warning mb-4">
        <strong>Important:</strong> Results cannot be changed after submission.
        Make sure every trainee has a result selected before clicking Submit.
    </div>

    <form asp-action="Record" asp-route-sessionId="@Model.SessionId" method="post">
        @Html.AntiForgeryToken()

        @* Hidden session-level fields for round-trip on validation failure *@
        <input type="hidden" name="SessionId" value="@Model.SessionId" />
        <input type="hidden" name="CourseTitle" value="@Model.CourseTitle" />
        <input type="hidden" name="SessionDate" value="@Model.SessionDate.ToString("yyyy-MM-dd")" />

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-top mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:5%">#</th>
                                <th style="width:25%">Trainee</th>
                                <th style="width:20%">Result <span class="text-danger">*</span></th>
                                <th>Remarks <span class="text-muted fw-normal">(optional)</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Trainees.Count; i++)
                            {
                                var row = Model.Trainees[i];
                                <tr>
                                    <td class="text-muted pt-3">@(i + 1)</td>

                                    <td class="fw-semibold pt-3">
                                        @row.TraineeName
                                        @* Hidden fields for round-trip *@
                                        <input type="hidden" name="Trainees[@i].EnrollmentId" value="@row.EnrollmentId" />
                                        <input type="hidden" name="Trainees[@i].TraineeId"    value="@row.TraineeId" />
                                        <input type="hidden" name="Trainees[@i].TraineeName"  value="@row.TraineeName" />
                                    </td>

                                    <td class="pt-2">
                                        <div class="d-flex gap-3">
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="radio"
                                                       id="pass-@i"
                                                       name="Trainees[@i].Result"
                                                       value="Pass"
                                                       checked="@(row.Result == "Pass")" />
                                                <label class="form-check-label text-success fw-semibold"
                                                       for="pass-@i">Pass</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="radio"
                                                       id="fail-@i"
                                                       name="Trainees[@i].Result"
                                                       value="Fail"
                                                       checked="@(row.Result == "Fail")" />
                                                <label class="form-check-label text-danger fw-semibold"
                                                       for="fail-@i">Fail</label>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="pt-2">
                                        <textarea name="Trainees[@i].Remarks"
                                                  class="form-control form-control-sm"
                                                  rows="2"
                                                  maxlength="500"
                                                  placeholder="Optional remarks…">@row.Remarks</textarea>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <span class="text-muted small">@Model.Trainees.Count trainee(s) to assess.</span>
                <button type="submit" class="btn btn-success px-4">
                    Submit All Results
                </button>
            </div>
        </div>
    </form>
}
