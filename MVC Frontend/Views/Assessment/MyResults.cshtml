@model MVC_Frontend.Models.MyResultsViewModel
@{
    ViewData["Title"] = "My Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">My Results</h1>
        <p class="text-muted mb-0">Your assessment results for completed sessions.</p>
    </div>
</div>

@if (!Model.Results.Any())
{
    <div class="alert alert-light border">
        You have no assessment results yet. Results appear here once a session is completed
        and your instructor submits them.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Session Date</th>
                            <th>Result</th>
                            <th>Instructor Remarks</th>
                            <th>Completion Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Results)
                        {
                            <tr>
                                <td class="fw-semibold">@r.CourseTitle</td>
                                <td>@r.SessionDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge fs-6 @(r.Result == "Pass" ? "bg-success" : "bg-danger")">
                                        @r.Result
                                    </span>
                                </td>
                                <td class="text-muted small">
                                    @(string.IsNullOrWhiteSpace(r.Remarks) ? "—" : r.Remarks)
                                </td>
                                <td>@r.CompletionDate.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small">
            @Model.Results.Count completed course(s).
        </div>
    </div>
}
