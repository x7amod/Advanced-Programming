@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account – Training Institute</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', system-ui, sans-serif; background: #fff; -webkit-font-smoothing: antialiased; }

        .auth-shell {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 100vh;
        }

        /* ── Left panel ── */
        .auth-left {
            display: flex;
            flex-direction: column;
            padding: 32px 48px;
            justify-content: space-between;
        }
        .auth-logo { height: 28px; width: auto; }
        .auth-form-wrap {
            max-width: 440px;
            width: 100%;
            align-self: center;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 32px 0;
        }
        .auth-title {
            font-size: 28px;
            font-weight: 700;
            color: #1A1A2E;
            letter-spacing: -0.01em;
            margin-bottom: 8px;
        }
        .auth-subtitle {
            font-size: 14px;
            color: #6B7280;
            margin-bottom: 24px;
            line-height: 22px;
        }
        .auth-footer-text { font-size: 12px; color: #9CA3AF; line-height: 16px; }

        /* ── Grid form layout ── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }
        .col-full { grid-column: 1 / -1; }

        /* ── Fields ── */
        .field { display: flex; flex-direction: column; gap: 6px; }
        .field label { font-size: 12px; font-weight: 600; color: #1A1A2E; }
        .field .hint { font-size: 12px; color: #6B7280; }

        input[type="text"],
        input[type="email"],
        input[type="password"],
        input[type="tel"],
        input[type="date"] {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid #E5E7EB;
            border-radius: 4px;
            background: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            color: #1A1A2E;
            outline: none;
            transition: border-color 150ms, box-shadow 150ms;
        }
        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="password"]:focus,
        input[type="tel"]:focus,
        input[type="date"]:focus {
            border-color: #0D9488;
            box-shadow: 0 0 0 3px rgba(13,148,136,.18);
        }
        input::placeholder { color: #9CA3AF; }

        /* ── Buttons ── */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 18px;
            background: #0D9488;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background 150ms;
            text-decoration: none;
        }
        .btn-primary:hover { background: #0F766E; }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 18px;
            background: #fff;
            color: #0D9488;
            border: 1px solid #0D9488;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background 150ms;
            text-decoration: none;
        }
        .btn-secondary:hover { background: rgba(13,148,136,.08); }

        /* ── Checkbox ── */
        .auth-check-label {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            font-size: 13px;
            color: #1A1A2E;
            line-height: 20px;
            cursor: pointer;
        }
        input[type="checkbox"] { accent-color: #0D9488; width: 14px; height: 14px; margin-top: 3px; flex: none; }
        .auth-link { color: #0D9488; text-decoration: none; }
        .auth-link:hover { color: #0F766E; }

        /* ── Validation summary ── */
        .validation-summary { background: #FEE2E2; color: #991B1B; border-radius: 8px; padding: 10px 14px; font-size: 13px; grid-column: 1/-1; }

        /* ── Right panel ── */
        .auth-right {
            position: relative;
            background-image: url('/assets/auth-panel.svg');
            background-size: cover;
            background-position: center;
            padding: 48px;
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }
        .auth-right-eyebrow {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            opacity: 0.85;
            margin-bottom: 12px;
        }
        .auth-right-headline {
            font-size: 32px;
            font-weight: 700;
            line-height: 40px;
            letter-spacing: -0.01em;
            max-width: 380px;
            margin-bottom: 14px;
        }
        .auth-right-body {
            font-size: 15px;
            line-height: 24px;
            opacity: 0.88;
            max-width: 380px;
        }

        @@media (max-width: 768px) {
            .auth-shell { grid-template-columns: 1fr; }
            .auth-right { display: none; }
            .auth-left { padding: 32px 24px; }
        }
    </style>
</head>
<body>
<div class="auth-shell">

    <!-- Left: form -->
    <div class="auth-left">
        <img class="auth-logo" src="~/assets/logo.svg" alt="Training Institute" />

        <div class="auth-form-wrap">
            <div class="auth-title">Create your account</div>
            <div class="auth-subtitle">Join as a trainee. Instructors and coordinators are invited by staff.</div>

            @* Abdullah wires: asp-controller="Account" asp-action="Register" method="post" *@
            <form method="post" action="#" class="form-grid">
                @Html.AntiForgeryToken()

                @if (ViewBag.Error != null)
                {
                    <div class="validation-summary">@ViewBag.Error</div>
                }

                <div class="field">
                    <label for="firstName">First name</label>
                    <input type="text" id="firstName" name="firstName" placeholder="Ahmed" />
                </div>

                <div class="field">
                    <label for="lastName">Last name</label>
                    <input type="text" id="lastName" name="lastName" placeholder="Al-Mansoori" />
                </div>

                <div class="field col-full">
                    <label for="email">Email address</label>
                    <input type="email" id="email" name="email" placeholder="you@example.bh" autocomplete="email" />
                </div>

                <div class="field">
                    <label for="dob">Date of birth</label>
                    <input type="date" id="dob" name="dateOfBirth" />
                </div>

                <div class="field">
                    <label for="phone">Phone number</label>
                    <input type="tel" id="phone" name="phone" placeholder="+973 3300 1234" />
                </div>

                <div class="field col-full">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="••••••••••" autocomplete="new-password" />
                    <span class="hint">Minimum 8 characters with one number.</span>
                </div>

                <div class="field col-full">
                    <label for="confirmPassword">Confirm password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••••" autocomplete="new-password" />
                </div>

                <label class="auth-check-label col-full">
                    <input type="checkbox" name="agreeTerms" />
                    <span>
                        I agree to the <a class="auth-link" href="#">terms of service</a>
                        and <a class="auth-link" href="#">privacy policy</a>.
                    </span>
                </label>

                <div class="col-full" style="display:flex; gap:10px; margin-top:4px;">
                    <a class="btn-secondary" asp-controller="Account" asp-action="Login">Back to sign in</a>
                    <button type="submit" class="btn-primary">Create account</button>
                </div>

            </form>
        </div>

        <div class="auth-footer-text">© @DateTime.Now.Year Training Institute · Bahrain Polytechnic</div>
    </div>

    <!-- Right: brand panel -->
    <div class="auth-right">
        <div class="auth-right-eyebrow">Training &amp; Certification</div>
        <div class="auth-right-headline">Manage every step from enrollment to certification.</div>
        <div class="auth-right-body">Bahrain's professional training platform for trainees, instructors, and coordinators.</div>
    </div>

</div>
</body>
</html>
