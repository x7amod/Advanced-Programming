@model IEnumerable<MVC_Frontend.Models.UserListViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Manage Users</h2>
    <div class="d-flex gap-2">
        <a asp-action="CreateInstructor" class="btn btn-outline-primary">+ Add Instructor</a>
        <a asp-action="CreateTrainee" class="btn btn-primary">+ Add Trainee</a>
    </div>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No users found.</p>
}
else
{
    var instructors = Model.Where(u => u.Role == "Instructor").ToList();
    var trainees = Model.Where(u => u.Role == "Trainee").ToList();

    @if (instructors.Any())
    {
        <h5 class="mt-4 mb-2 text-muted fw-semibold">Instructors</h5>
        <table class="table table-hover mb-4">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in instructors)
                {
                    <tr>
                        <td class="fw-semibold">@u.Username</td>
                        <td class="text-muted">@u.Email</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(u.Phone) ? "—" : u.Phone)</td>
                        <td class="text-end">
                            <a asp-action="EditInstructor" asp-route-id="@u.ProfileId"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="ChangeRole" asp-route-userId="@u.UserId"
                               class="btn btn-sm btn-outline-warning">Change Role</a>
                            <a asp-action="DeleteInstructor" asp-route-id="@u.ProfileId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (trainees.Any())
    {
        <h5 class="mt-2 mb-2 text-muted fw-semibold">Trainees</h5>
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in trainees)
                {
                    <tr>
                        <td class="fw-semibold">@u.Username</td>
                        <td class="text-muted">@u.Email</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(u.Phone) ? "—" : u.Phone)</td>
                        <td class="text-end">
                            <a asp-action="EditTrainee" asp-route-id="@u.ProfileId"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="ChangeRole" asp-route-userId="@u.UserId"
                               class="btn btn-sm btn-outline-warning">Change Role</a>
                            <a asp-action="DeleteTrainee" asp-route-id="@u.ProfileId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
