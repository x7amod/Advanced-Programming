@model MVC_Frontend.Models.ChangeRoleViewModel
@using Web_API.Models
@{
    ViewData["Title"] = "Change Role";
    var otherRole = Model.CurrentRole == AppRoles.Trainee ? AppRoles.Instructor : AppRoles.Trainee;
    var otherRoleLabel = Model.CurrentRole == AppRoles.Trainee ? "Instructor" : "Trainee";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Manage Users</a></li>
        <li class="breadcrumb-item active">Change Role</li>
    </ol>
</nav>

<h2 class="mb-4">Change Role</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <p class="mb-1"><strong>@Model.Username</strong></p>
                <p class="text-muted mb-3">@Model.Email</p>

                <div class="alert alert-warning small mb-4">
                    Changing this user's role will remove their current profile record and create a new one.
                    You will be redirected to complete the new profile details after the change.
                </div>

                <form asp-action="ChangeRole" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="Username" type="hidden" />
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="CurrentRole" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label">Current Role</label>
                        <input type="text" class="form-control" value="@Model.CurrentRole" disabled />
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewRole" class="form-label"></label>
                        <select asp-for="NewRole" class="form-select">
                            <option value="">— Select new role —</option>
                            <option value="@otherRole">@otherRoleLabel</option>
                        </select>
                        <span asp-validation-for="NewRole" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Change Role</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
