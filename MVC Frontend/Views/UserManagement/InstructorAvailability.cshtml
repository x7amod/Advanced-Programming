@model IEnumerable<MVC_Frontend.Models.AvailabilityItemViewModel>
@{
    ViewData["Title"] = "Instructor Availability";
    var instructorId   = (int)ViewBag.InstructorId;
    var instructorName = (string)ViewBag.InstructorName;
    var days = new[]
    {
        new { Value = 0, Text = "Sunday" },
        new { Value = 1, Text = "Monday" },
        new { Value = 2, Text = "Tuesday" },
        new { Value = 3, Text = "Wednesday" },
        new { Value = 4, Text = "Thursday" },
        new { Value = 5, Text = "Friday" },
        new { Value = 6, Text = "Saturday" }
    };
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">Availability — @instructorName</h1>
        <p class="text-muted mb-0">Define the weekly time slots during which this instructor is available to teach.</p>
    </div>
    <a asp-action="EditInstructor" asp-route-id="@instructorId" class="btn btn-outline-secondary btn-sm">
        Back to Instructor
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Current slots -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold">Current Availability Slots</div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <p class="text-muted p-3 mb-0">
                No availability slots defined. The instructor is currently treated as
                <strong>always available</strong>. Add slots to restrict scheduling to specific times.
            </p>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Day</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Effective From</th>
                        <th>Effective To</th>
                        <th>Recurring</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var slot in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@slot.DayName</td>
                            <td>@slot.StartTime</td>
                            <td>@slot.EndTime</td>
                            <td>@slot.EffectiveFrom.ToString("dd MMM yyyy")</td>
                            <td>@(slot.EffectiveTo.HasValue ? slot.EffectiveTo.Value.ToString("dd MMM yyyy") : "—")</td>
                            <td>
                                @if (slot.IsRecurring)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="RemoveAvailability" method="post" class="d-inline"
                                      onsubmit="return confirm('Remove this availability slot?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="availabilityId" value="@slot.AvailabilityId" />
                                    <input type="hidden" name="instructorId"   value="@slot.InstructorId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Add slot form -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">Add Availability Slot</div>
    <div class="card-body">
        <form asp-action="AddAvailability" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="InstructorId" value="@instructorId" />

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Day of Week</label>
                    <select name="DayOfWeek" class="form-select" required>
                        <option value="">— Select —</option>
                        @foreach (var d in days)
                        {
                            <option value="@d.Value">@d.Text</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Start Time</label>
                    <input type="time" name="StartTime" class="form-control" required />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">End Time</label>
                    <input type="time" name="EndTime" class="form-control" required />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Effective From</label>
                    <input type="date" name="EffectiveFrom"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")"
                           class="form-control" required />
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-semibold">Effective To</label>
                    <input type="date" name="EffectiveTo" class="form-control" />
                    <div class="form-text">Leave blank for no end date.</div>
                </div>

                <div class="col-md-1 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="IsRecurring"
                               value="true" id="isRecurring" checked />
                        <label class="form-check-label" for="isRecurring">Weekly</label>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Add Slot</button>
            </div>
        </form>
    </div>
</div>
