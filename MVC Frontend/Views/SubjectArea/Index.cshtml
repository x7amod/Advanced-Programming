@model IEnumerable<SubjectArea>
@{
    ViewData["Title"] = "Subject Areas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Subject Areas</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Subject Area</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <p class="text-muted">No subject areas defined yet.</p>
}
else
{
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Courses</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var area in Model)
            {
                <tr>
                    <td class="fw-semibold">@area.Name</td>
                    <td class="text-muted small">
                        @(area.Description?.Length > 80
                            ? area.Description[..80] + "…"
                            : area.Description ?? "—")
                    </td>
                    <td>
                        <a asp-controller="Course" asp-action="Index" asp-route-subjectAreaId="@area.SubjectAreaId"
                           class="badge bg-primary text-decoration-none">
                            @area.Courses.Count courses
                        </a>
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@area.SubjectAreaId"
                           class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@area.SubjectAreaId" method="post"
                              class="d-inline"
                              onsubmit="return confirm('Delete subject area \'@area.Name\'?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
