@model MVC_Frontend.Models.NotificationIndexViewModel
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Notifications</h1>
        <p class="text-muted mb-0">
            @Model.UnreadCount unread notification@(Model.UnreadCount == 1 ? "" : "s")
        </p>
    </div>
    @if (Model.UnreadCount > 0)
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary btn-sm">Mark All as Read</button>
        </form>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Notifications.Any())
        {
            <div class="text-center text-muted py-5">
                <svg class="mb-3" width="40" height="40" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.4">
                    <path d="M6 16h12l-1.4-2V11a4.6 4.6 0 0 0-9.2 0v3z"/>
                    <path d="M10 19a2 2 0 0 0 4 0"/>
                </svg>
                <p class="mb-0">No notifications yet.</p>
            </div>
        }
        @foreach (var n in Model.Notifications)
        {
            var rowClass = n.IsRead ? "border-bottom" : "border-bottom bg-light";
            var typeIcon = n.Type switch
            {
                "Enrollment"    => "📋",
                "Assessment"    => "📝",
                "Certification" => "🎓",
                "Payment"       => "💳",
                _               => "🔔"
            };
            <div class="d-flex align-items-start gap-3 p-3 @rowClass">
                <div class="fs-4 pt-1">@typeIcon</div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="fw-semibold mb-1 @(n.IsRead ? "text-muted" : "")">@n.Title</p>
                        <small class="text-muted ms-3 text-nowrap">@n.TimeAgo</small>
                    </div>
                    <p class="mb-1 small @(n.IsRead ? "text-muted" : "")">@n.Message</p>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" asp-route-id="@n.NotificationId"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link btn-sm p-0 text-decoration-none">
                                Mark as read
                            </button>
                        </form>
                    }
                </div>
                @if (!n.IsRead)
                {
                    <span class="badge bg-primary rounded-pill mt-1">New</span>
                }
            </div>
        }
    </div>
</div>
