@{
    Layout = null;
    ViewData["Title"] = "Taalam — Training & certification platform";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body class="tl-landing">
    <header class="nav">
        <a class="brand" href="@Url.Action("Index", "Landing")">
            <img class="auth-logo" src="@Url.Content("~/assets/logo.svg")" alt="Training Institute" />

        </a>
        <nav class="nav-actions">
            <a class="btn btn-ghost" href="@Url.Action("Login", "Account")">Log in</a>
            <a class="btn btn-primary" href="@Url.Action("Register", "Account")">Register</a>
        </nav>
    </header>

    <main>
        <section class="hero">
            <span class="eyebrow">Training &amp; certification, Bahrain</span>
            <h1>Manage the full training lifecycle, end to end.</h1>
            <p>
                Taalam brings courses, sessions, enrollments, assessments and certifications
                into one clean platform — for trainees, instructors and coordinators.
            </p>
            <div class="hero-actions">
                <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "Course")">Browse courses</a>
                <a class="btn btn-secondary btn-lg" href="@Url.Action("CertificationLookup", "Public")">Verify a certificate</a>
            </div>
        </section>

        <section class="features">
            <article class="card">
                <span class="card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h12a3 3 0 0 1 3 3v11H7a3 3 0 0 1-3-3z" /><path d="M4 5v11" /></svg>
                </span>
                <h3>Browse the catalogue</h3>
                <p>Explore instructor-led courses across subjects, with schedules, capacity and certification tracks.</p>
                <a class="card-link" href="@Url.Action("Index", "Course")">View courses →</a>
            </article>

            <article class="card">
                <span class="card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="5" /><path d="M9 14l-2 7 5-3 5 3-2-7" /></svg>
                </span>
                <h3>Verify a certificate</h3>
                <p>Employers and trainees can confirm certification status with a trainee ID and certificate number — no account needed.</p>
                <a class="card-link" href="@Url.Action("CertificationLookup", "Public")">Verify now →</a>
            </article>

            <article class="card">
                <span class="card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                </span>
                <h3>Your training, tracked</h3>
                <p>Sign in to enroll, follow your progress toward certification, and manage payments in one place.</p>
                <a class="card-link" href="@Url.Action("Login", "Account")">Log in →</a>
            </article>
        </section>
    </main>

    <footer class="foot">
        © @DateTime.Now.Year Taalam · Training &amp; certification platform
    </footer>
</body>
</html>
