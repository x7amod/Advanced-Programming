@model MVC_Frontend.Models.MyPaymentsViewModel
@{
    ViewData["Title"] = "My Payments";
}

<div class="mb-4">
    <h1 class="h3 mb-1">My Payments</h1>
    <p class="text-muted mb-0">View your enrollment invoices and payment history.</p>
</div>

<!-- ── Summary Cards ──────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <p class="text-muted small mb-1">Total Invoiced</p>
                <h5 class="mb-0">@Model.TotalOwed.ToString("C")</h5>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <p class="text-muted small mb-1">Total Paid</p>
                <h5 class="mb-0 text-success">@Model.TotalPaid.ToString("C")</h5>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <p class="text-muted small mb-1">Outstanding Balance</p>
                <h5 class="mb-0 @(Model.Outstanding > 0 ? "text-danger" : "text-success")">
                    @Model.Outstanding.ToString("C")
                </h5>
            </div>
        </div>
    </div>
</div>

<!-- ── Payments Table ─────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Course</th>
                        <th>Session Date</th>
                        <th>Invoice Total</th>
                        <th>Paid</th>
                        <th>Outstanding</th>
                        <th>Due Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Records.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No payment records found.</td></tr>
                    }
                    @foreach (var r in Model.Records)
                    {
                        var badgeClass = r.Status switch
                        {
                            "Paid"    => "bg-success",
                            "Partial" => "bg-warning text-dark",
                            "Overdue" => "bg-danger",
                            _         => "bg-secondary"
                        };
                        <tr class="@(r.IsOverdue ? "table-danger" : "")">
                            <td class="fw-semibold">@r.CourseTitle</td>
                            <td>@r.SessionDate.ToString("MMM dd, yyyy")</td>
                            <td>@r.TotalAmount.ToString("C")</td>
                            <td class="text-success">@r.PaidAmount.ToString("C")</td>
                            <td class="@(r.OutstandingAmount > 0 ? "text-danger fw-semibold" : "")">
                                @r.OutstandingAmount.ToString("C")
                            </td>
                            <td>
                                @r.DueDate.ToString("MMM dd, yyyy")
                                @if (r.IsOverdue)
                                {
                                    <span class="badge bg-danger ms-1">Overdue</span>
                                }
                            </td>
                            <td><span class="badge @badgeClass">@r.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
