@model MVC_Frontend.Models.PaymentIndexViewModel
@{
    ViewData["Title"] = "Payment Records";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Payment Records</h1>
        <p class="text-muted mb-0">Manage enrollment fees and payments.</p>
    </div>
</div>

<!-- ── Summary Cards ──────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="text-muted small mb-1">Total Collected</p>
                <h4 class="mb-0 text-success">@Model.TotalCollected.ToString("C")</h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="text-muted small mb-1">Total Outstanding</p>
                <h4 class="mb-0 text-danger">@Model.TotalOutstanding.ToString("C")</h4>
            </div>
        </div>
    </div>
</div>

<!-- ── Filter ─────────────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Status</label>
                <select name="filterStatus" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    @foreach (var s in Model.Statuses)
                    {
                        <option value="@s.Value" selected="@(s.Value == Model.FilterStatus)">@s.Text</option>
                    }
                </select>
            </div>
            <div class="col-sm-auto">
                <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- ── Records Table ──────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Trainee</th>
                        <th>Course</th>
                        <th>Session Date</th>
                        <th>Total</th>
                        <th>Paid</th>
                        <th>Outstanding</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Records.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">No payment records found.</td></tr>
                    }
                    @foreach (var r in Model.Records)
                    {
                        var badgeClass = r.Status switch
                        {
                            "Paid"    => "bg-success",
                            "Partial" => "bg-warning text-dark",
                            "Overdue" => "bg-danger",
                            _         => "bg-secondary"
                        };
                        <tr class="@(r.IsOverdue ? "table-danger" : "")">
                            <td class="fw-semibold">@r.TraineeName</td>
                            <td>@r.CourseTitle</td>
                            <td>@r.SessionDate.ToString("MMM dd, yyyy")</td>
                            <td>@r.TotalAmount.ToString("C")</td>
                            <td class="text-success">@r.PaidAmount.ToString("C")</td>
                            <td class="@(r.OutstandingAmount > 0 ? "text-danger fw-semibold" : "")">
                                @r.OutstandingAmount.ToString("C")
                            </td>
                            <td>
                                @r.DueDate.ToString("MMM dd, yyyy")
                                @if (r.IsOverdue)
                                {
                                    <span class="badge bg-danger ms-1">Overdue</span>
                                }
                            </td>
                            <td><span class="badge @badgeClass">@r.Status</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@r.PaymentRecordId"
                                   class="btn btn-sm btn-outline-primary me-1">Details</a>
                                @if (r.Status != "Paid")
                                {
                                    <a asp-action="RecordTransaction" asp-route-paymentRecordId="@r.PaymentRecordId"
                                       class="btn btn-sm btn-outline-success">Record Payment</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
