@model MVC_Frontend.Models.CreatePaymentRecordViewModel
@{
    ViewData["Title"] = "Create Payment Record";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Create Payment Record</h1>
        <p class="text-muted mb-0">Issue an invoice for an enrollment.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</div>

<div class="card border-0 shadow-sm" style="max-width:560px;">
    <div class="card-body">

        <!-- Read-only enrollment info -->
        <div class="mb-3">
            <label class="form-label small text-muted">Trainee</label>
            <p class="fw-semibold mb-0">@Model.TraineeName</p>
        </div>
        <div class="mb-3">
            <label class="form-label small text-muted">Course</label>
            <p class="fw-semibold mb-0">@Model.CourseTitle</p>
        </div>
        <div class="mb-4">
            <label class="form-label small text-muted">Session Date</label>
            <p class="fw-semibold mb-0">@Model.SessionDate.ToString("MMM dd, yyyy")</p>
        </div>

        <hr />

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EnrollmentId" />
            <input type="hidden" asp-for="TraineeName" />
            <input type="hidden" asp-for="CourseTitle" />
            <input type="hidden" asp-for="SessionDate" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="TotalAmount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">BHD</span>
                    <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" min="0.01" />
                </div>
                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create Invoice</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
