@model Reporting_App.Models.RevenueStatsViewModel
@{
    ViewData["Title"] = "Revenue Report";
}

<div class="rp-page-header">
    <a asp-controller="Reports" asp-action="Index" class="rp-back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
        </svg>
        Back to dashboard
    </a>
    <div class="rp-page-title">Revenue Report</div>
    <div class="rp-page-subtitle">Invoiced vs collected, by course and by month.</div>
</div>

@* ──── KPI CARDS ──── *@
<div class="rp-stats-grid rp-stats-grid-5">
    @* Total Invoiced *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Total Invoiced</div>
            <div class="rp-stat-icon" style="background: #CCFBF1; color: #0D9488;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="13" rx="2" />
                    <path d="M3 10h18" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">BHD @Model.Summary.TotalRevenue.ToString("N3")</div>
    </div>

    @* Collected *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Collected</div>
            <div class="rp-stat-icon" style="background: #D1FAE5; color: #065F46;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12l5 5L20 7" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">BHD @Model.Summary.TotalCollected.ToString("N3")</div>
    </div>

    @* Outstanding *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Outstanding</div>
            <div class="rp-stat-icon" style="background: #FEF3C7; color: #92400E;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v5l3 2" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">BHD @Model.Summary.TotalOutstanding.ToString("N3")</div>
    </div>

    @* Collection Rate *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Collection Rate</div>
            <div class="rp-stat-icon" style="background: #DBEAFE; color: #1E40AF;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 20V10M10 20V4M16 20v-7M22 20H2" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.CollectionRate.ToString("0.0")%</div>
    </div>

    @* Overdue Invoices *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Overdue Invoices</div>
            <div class="rp-stat-icon" style="background: #FEE2E2; color: #991B1B;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 6l12 12M18 6 6 18" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.OverdueCount</div>
    </div>
</div>

@* ──── BY COURSE TABLE ──── *@
<div class="rp-section-title">By Course</div>
<div class="rp-card-noPad">
    @if (!Model.ByCourse.Any())
    {
        <div class="rp-table-empty">No revenue data available.</div>
    }
    else
    {
        <div class="rp-table-wrapper">
            <table class="rp-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Course Title</th>
                        <th class="right">Invoiced</th>
                        <th class="right">Collected</th>
                        <th class="right">Outstanding</th>
                        <th class="right">Overdue</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ByCourse)
                    {
                        <tr>
                            <td class="mono">@row.CourseCode</td>
                            <td style="font-weight: 500;">@row.CourseTitle</td>
                            <td class="right num">BHD @row.TotalInvoiced.ToString("N3")</td>
                            <td class="right num green">BHD @row.TotalCollected.ToString("N3")</td>
                            <td class="right num @(row.Outstanding > 0 ? "red" : "muted")">BHD @row.Outstanding.ToString("N3")</td>
                            <td class="right num @(row.OverdueCount > 0 ? "red" : "muted")">@row.OverdueCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ──── BY MONTH TABLE ──── *@
<div class="rp-section-title">By Month</div>
<div class="rp-card-noPad">
    @if (!Model.ByMonth.Any())
    {
        <div class="rp-table-empty">No monthly data available.</div>
    }
    else
    {
        <div class="rp-table-wrapper">
            <table class="rp-table">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th class="right">Invoiced</th>
                        <th class="right">Collected</th>
                        <th class="right">Collection Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ByMonth)
                    {
                        var rate = row.TotalInvoiced == 0 ? 0 : Math.Round((double)row.TotalCollected / (double)row.TotalInvoiced * 100, 1);
                        <tr>
                            <td style="font-weight: 500;">@row.MonthName</td>
                            <td class="right num">BHD @row.TotalInvoiced.ToString("N3")</td>
                            <td class="right num green">BHD @row.TotalCollected.ToString("N3")</td>
                            <td class="right">
                                <div class="rp-progress">
                                    <div class="rp-progress-track">
                                        <div class="rp-progress-fill" style="width: @rate%"></div>
                                    </div>
                                    <span class="rp-progress-label">@rate.ToString("0")%</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
