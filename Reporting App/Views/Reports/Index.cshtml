@model Reporting_App.Models.OverviewViewModel
@{
    ViewData["Title"] = "Reporting Dashboard";
}

<div class="rp-page-header">
    <div class="rp-page-title">Reporting Dashboard</div>
    <div class="rp-page-subtitle">Operational insights across the institute, as of today.</div>
</div>

@* ──── KPI STAT CARDS ──── *@
<div class="rp-stats-grid rp-stats-grid-4">
    @* Total Enrollments *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Total Enrollments</div>
            <div class="rp-stat-icon" style="background: #CCFBF1; color: #0D9488;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="6" y="4" width="12" height="17" rx="2" />
                    <path d="M9 4h6v3H9z" />
                    <path d="M9 12l2 2 4-4" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.TotalEnrollments</div>
        <div class="rp-stat-hint">@Model.CompletedEnrollments completed</div>
    </div>

    @* Revenue Collected *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Revenue Collected</div>
            <div class="rp-stat-icon" style="background: #D1FAE5; color: #065F46;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="13" rx="2" />
                    <path d="M3 10h18" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">BHD @Model.TotalCollected.ToString("N3")</div>
        <div class="rp-stat-hint">of BHD @Model.TotalRevenue.ToString("N3") invoiced</div>
    </div>

    @* Certifications Issued *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Certifications Issued</div>
            <div class="rp-stat-icon" style="background: #DBEAFE; color: #1E40AF;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="9" r="5" />
                    <path d="M9 14l-2 7 5-3 5 3-2-7" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.TotalCertificationsIssued</div>
        <div class="rp-stat-hint">across all tracks</div>
    </div>

    @* Overall Pass Rate *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Overall Pass Rate</div>
            <div class="rp-stat-icon" style="background: #FEF3C7; color: #92400E;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 20V10M10 20V4M16 20v-7M22 20H2" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.OverallPassRate.ToString("0.0")%</div>
        <div class="rp-stat-hint">across all assessments</div>
    </div>
</div>

@* ──── REPORT NAVIGATION CARDS ──── *@
<div class="rp-nav-grid">
    @* Enrollment Statistics *@
    <div class="rp-nav-card">
        <div class="rp-nav-card-inner">
            <div class="rp-nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="6" y="4" width="12" height="17" rx="2" />
                    <path d="M9 4h6v3H9z" />
                    <path d="M9 12l2 2 4-4" />
                </svg>
            </div>
            <div>
                <div class="rp-nav-card-title">Enrollment Statistics</div>
                <div class="rp-nav-card-desc">Enrollment trends by course and category.</div>
            </div>
        </div>
        <a asp-controller="Reports" asp-action="Enrollments" class="rp-btn-secondary">View report</a>
    </div>

    @* Instructor Workload *@
    <div class="rp-nav-card">
        <div class="rp-nav-card-inner">
            <div class="rp-nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3.5" />
                    <path d="M2.5 19a6.5 6.5 0 0 1 13 0" />
                    <circle cx="17" cy="10" r="2.8" />
                    <path d="M21.5 18a4.5 4.5 0 0 0-6-3.4" />
                </svg>
            </div>
            <div>
                <div class="rp-nav-card-title">Instructor Workload</div>
                <div class="rp-nav-card-desc">Session counts and pass rates by instructor.</div>
            </div>
        </div>
        <a asp-controller="Reports" asp-action="Instructors" class="rp-btn-secondary">View report</a>
    </div>

    @* Certification Report *@
    <div class="rp-nav-card">
        <div class="rp-nav-card-inner">
            <div class="rp-nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="9" r="5" />
                    <path d="M9 14l-2 7 5-3 5 3-2-7" />
                </svg>
            </div>
            <div>
                <div class="rp-nav-card-title">Certification Report</div>
                <div class="rp-nav-card-desc">Completion rates across certification tracks.</div>
            </div>
        </div>
        <a asp-controller="Reports" asp-action="Certifications" class="rp-btn-secondary">View report</a>
    </div>

    @* Revenue Report *@
    <div class="rp-nav-card">
        <div class="rp-nav-card-inner">
            <div class="rp-nav-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="13" rx="2" />
                    <path d="M3 10h18" />
                </svg>
            </div>
            <div>
                <div class="rp-nav-card-title">Revenue Report</div>
                <div class="rp-nav-card-desc">Collected vs outstanding payments.</div>
            </div>
        </div>
        <a asp-controller="Reports" asp-action="Revenue" class="rp-btn-secondary">View report</a>
    </div>
</div>
