@model Reporting_App.Models.EnrollmentStatsViewModel
@{
    ViewData["Title"] = "Enrollment Statistics";
}

<div class="rp-page-header">
    <a asp-controller="Reports" asp-action="Index" class="rp-back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
        </svg>
        Back to dashboard
    </a>
    <div class="rp-page-title">Enrollment Statistics</div>
    <div class="rp-page-subtitle">Course-level enrollment outcomes.</div>
</div>

@* ──── KPI CARDS ──── *@
<div class="rp-stats-grid rp-stats-grid-5">
    @* Total *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Total</div>
            <div class="rp-stat-icon" style="background: #CCFBF1; color: #0D9488;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="6" y="4" width="12" height="17" rx="2" />
                    <path d="M9 4h6v3H9z" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalEnrollments</div>
    </div>

    @* Completed *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Completed</div>
            <div class="rp-stat-icon" style="background: #D1FAE5; color: #065F46;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12l5 5L20 7" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalCompleted</div>
    </div>

    @* Dropped *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Dropped</div>
            <div class="rp-stat-icon" style="background: #FEE2E2; color: #991B1B;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 6l12 12M18 6 6 18" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalDropped</div>
    </div>

    @* Active *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Active</div>
            <div class="rp-stat-icon" style="background: #DBEAFE; color: #1E40AF;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3.5" />
                    <path d="M2.5 19a6.5 6.5 0 0 1 13 0" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalActive</div>
    </div>

    @* Completion Rate *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Completion Rate</div>
            <div class="rp-stat-icon" style="background: #FEF3C7; color: #92400E;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 20V10M10 20V4M16 20v-7M22 20H2" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.OverallCompletionRate.ToString("0.0")%</div>
    </div>
</div>

@* ──── TABLE ──── *@
<div class="rp-card-noPad">
    @if (!Model.ByCourse.Any())
    {
        <div class="rp-table-empty">No enrollment data available.</div>
    }
    else
    {
        <div class="rp-table-wrapper">
            <table class="rp-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Course Title</th>
                        <th>Category</th>
                        <th class="right">Enrolled</th>
                        <th class="right">Completed</th>
                        <th class="right">Dropped</th>
                        <th class="right">Active</th>
                        <th class="right">Completion Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ByCourse)
                    {
                        <tr>
                            <td class="mono">@row.CourseCode</td>
                            <td style="font-weight: 500;">@row.CourseTitle</td>
                            <td class="rp-text-muted">@row.CategoryName</td>
                            <td class="right num">@row.TotalEnrollments</td>
                            <td class="right num green">@row.Completed</td>
                            <td class="right num red">@row.Dropped</td>
                            <td class="right num">@row.Active</td>
                            <td class="right">
                                <div class="rp-progress">
                                    <div class="rp-progress-track">
                                        <div class="rp-progress-fill" style="width: @row.CompletionRate%"></div>
                                    </div>
                                    <span class="rp-progress-label">@row.CompletionRate.ToString("0")%</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
