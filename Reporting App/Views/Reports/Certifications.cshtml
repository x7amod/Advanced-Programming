@model Reporting_App.Models.CertificationStatsViewModel
@{
    ViewData["Title"] = "Certification Report";
}

<div class="rp-page-header">
    <a asp-controller="Reports" asp-action="Index" class="rp-back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
        </svg>
        Back to dashboard
    </a>
    <div class="rp-page-title">Certification Report</div>
    <div class="rp-page-subtitle">Completion across certification tracks.</div>
</div>

@* ──── KPI CARDS ──── *@
<div class="rp-stats-grid rp-stats-grid-4">
    @* Total Tracks *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Total Tracks</div>
            <div class="rp-stat-icon" style="background: #CCFBF1; color: #0D9488;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="9" r="5" />
                    <path d="M9 14l-2 7 5-3 5 3-2-7" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalTracks</div>
    </div>

    @* Certifications Issued *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Certifications Issued</div>
            <div class="rp-stat-icon" style="background: #D1FAE5; color: #065F46;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12l5 5L20 7" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalIssued</div>
    </div>

    @* In Progress *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">In Progress</div>
            <div class="rp-stat-icon" style="background: #DBEAFE; color: #1E40AF;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v5l3 2" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalInProgress</div>
    </div>

    @* Expired *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Expired</div>
            <div class="rp-stat-icon" style="background: #FEE2E2; color: #991B1B;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 6l12 12M18 6 6 18" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalExpired</div>
    </div>
</div>

@* ──── TABLE ──── *@
<div class="rp-card-noPad">
    @if (!Model.ByTrack.Any())
    {
        <div class="rp-table-empty">No certification data available.</div>
    }
    else
    {
        <table class="rp-table">
            <thead>
                <tr>
                    <th>Track</th>
                    <th class="right">Required Courses</th>
                    <th class="right">Enrolled</th>
                    <th class="right">Issued</th>
                    <th class="right">Eligible</th>
                    <th class="right">In Progress</th>
                    <th class="right">Expired</th>
                    <th class="right">Completion Rate</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.ByTrack)
                {
                    <tr>
                        <td>
                            <div class="rp-flex rp-gap-md" style="align-items: center;">
                                <div class="rp-stat-icon" style="background: #CCFBF1; color: #0F766E; width: 32px; height: 32px;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="9" r="5" />
                                        <path d="M9 14l-2 7 5-3 5 3-2-7" />
                                    </svg>
                                </div>
                                <span style="font-weight: 500;">@row.TrackName</span>
                            </div>
                        </td>
                        <td class="right num">@row.RequiredCoursesCount</td>
                        <td class="right num">@row.TotalEnrolled</td>
                        <td class="right num green">@row.Issued</td>
                        <td class="right num">@row.Eligible</td>
                        <td class="right num" style="color: #1E40AF;">@row.InProgress</td>
                        <td class="right num red">@row.Expired</td>
                        <td class="right">
                            <div class="rp-progress">
                                <div class="rp-progress-track">
                                    <div class="rp-progress-fill" style="width: @row.CompletionRate%"></div>
                                </div>
                                <span class="rp-progress-label">@row.CompletionRate.ToString("0")%</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
