@model Reporting_App.Models.InstructorStatsViewModel
@{
    ViewData["Title"] = "Instructor Workload";
}

<div class="rp-page-header">
    <a asp-controller="Reports" asp-action="Index" class="rp-back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
        </svg>
        Back to dashboard
    </a>
    <div class="rp-page-title">Instructor Workload</div>
    <div class="rp-page-subtitle">Sessions, trainees, and pass rates per instructor.</div>
</div>

@* ──── KPI CARDS ──── *@
<div class="rp-stats-grid rp-stats-grid-3">
    @* Total Instructors *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Total Instructors</div>
            <div class="rp-stat-icon" style="background: #CCFBF1; color: #0D9488;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3.5" />
                    <path d="M2.5 19a6.5 6.5 0 0 1 13 0" />
                    <circle cx="17" cy="10" r="2.8" />
                    <path d="M21.5 18a4.5 4.5 0 0 0-6-3.4" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.TotalInstructors</div>
    </div>

    @* Avg Sessions Per Instructor *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Avg Sessions Per Instructor</div>
            <div class="rp-stat-icon" style="background: #DBEAFE; color: #1E40AF;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="5" width="16" height="15" rx="2" />
                    <path d="M8 3v4M16 3v4M4 10h16" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.AvgSessionsPerInstructor.ToString("0.0")</div>
    </div>

    @* Avg Pass Rate *@
    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <div class="rp-stat-label">Avg Pass Rate</div>
            <div class="rp-stat-icon" style="background: #FEF3C7; color: #92400E;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 20V10M10 20V4M16 20v-7M22 20H2" />
                </svg>
            </div>
        </div>
        <div class="rp-stat-value">@Model.Summary.AvgPassRate.ToString("0.0")%</div>
    </div>
</div>

@* ──── TABLE ──── *@
<div class="rp-card-noPad">
    @if (!Model.ByInstructor.Any())
    {
        <div class="rp-table-empty">No instructor data available.</div>
    }
    else
    {
        <div class="rp-table-wrapper">
            <table class="rp-table">
                <thead>
                    <tr>
                        <th>Instructor</th>
                        <th>Email</th>
                        <th class="right">Sessions</th>
                        <th class="right">Completed</th>
                        <th class="right">Trainees</th>
                        <th class="right">Assessments</th>
                        <th class="right">Pass Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.ByInstructor)
                    {
                        var initials = string.Join("", (row.Name ?? "??").Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString().ToUpper() : ""));
                        var badgeClass = row.AvgPassRate >= 80 ? "rp-rate-green" : row.AvgPassRate >= 60 ? "rp-rate-orange" : "rp-rate-red";
                        <tr>
                            <td>
                                <div class="rp-flex rp-gap-md" style="align-items: center;">
                                    <div class="rp-avatar" style="width: 28px; height: 28px; font-size: 10px;">@initials</div>
                                    <span style="font-weight: 500;">@row.Name</span>
                                </div>
                            </td>
                            <td class="rp-text-muted">@row.Email</td>
                            <td class="right num">@row.TotalSessions</td>
                            <td class="right num">@row.CompletedSessions</td>
                            <td class="right num">@row.TotalTrainees</td>
                            <td class="right num">@row.TotalAssessments</td>
                            <td class="right">
                                <span class="rp-rate-badge @badgeClass">@row.AvgPassRate.ToString("0.0")%</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
