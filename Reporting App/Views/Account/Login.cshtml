@model Reporting_App.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reporting Portal – Taalam</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #fff;
            -webkit-font-smoothing: antialiased;
        }

        .auth-shell {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 100vh;
        }

        .auth-left {
            display: flex;
            flex-direction: column;
            padding: 32px 48px;
            justify-content: space-between;
        }

        .auth-logo {
            height: 28px;
            width: auto;
        }

        .auth-form-wrap {
            max-width: 400px;
            width: 100%;
            align-self: center;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 40px 0;
        }

        .auth-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 4px 12px;
            border-radius: 9999px;
            background: #CCFBF1;
            color: #0F766E;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            align-self: flex-start;
            margin-bottom: 14px;
        }

        .auth-badge-dot {
            width: 6px;
            height: 6px;
            border-radius: 999px;
            background: #0D9488;
        }

        .auth-title {
            font-size: 28px;
            font-weight: 700;
            color: #1A1A2E;
            letter-spacing: -0.01em;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            font-size: 14px;
            color: #6B7280;
            margin-bottom: 28px;
            line-height: 22px;
        }

        .auth-footer-text {
            font-size: 12px;
            color: #9CA3AF;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

            .field label {
                font-size: 12px;
                font-weight: 600;
                color: #1A1A2E;
            }

        input[type="email"], input[type="password"] {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid #E5E7EB;
            border-radius: 4px;
            background: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            color: #1A1A2E;
            outline: none;
            transition: border-color 150ms, box-shadow 150ms;
        }

            input[type="email"]:focus, input[type="password"]:focus {
                border-color: #0D9488;
                box-shadow: 0 0 0 3px rgba(13,148,136,0.18);
            }

        input::placeholder {
            color: #9CA3AF;
        }

        .btn-primary {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 10px 16px;
            background: #0D9488;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background 150ms;
        }

            .btn-primary:hover {
                background: #0F766E;
            }

        .validation-error {
            background: #FEE2E2;
            color: #991B1B;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
        }

        .auth-right {
            position: relative;
            background-image: url('/assets/auth-panel.svg');
            background-size: cover;
            background-position: center;
            padding: 48px;
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }

        .auth-right-eyebrow {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            opacity: 0.85;
            margin-bottom: 12px;
        }

        .auth-right-headline {
            font-size: 36px;
            font-weight: 700;
            line-height: 44px;
            letter-spacing: -0.01em;
            max-width: 420px;
            margin-bottom: 14px;
        }

        .auth-right-body {
            font-size: 15px;
            line-height: 24px;
            opacity: 0.88;
            max-width: 420px;
        }

        @@media (max-width: 768px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }

            .auth-right {
                display: none;
            }

            .auth-left {
                padding: 32px 24px;
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <div class="auth-left">
            <img class="auth-logo" src="/assets/logo.svg" alt="Taalam" />

            <div class="auth-form-wrap">
                <div class="auth-badge">
                    <span class="auth-badge-dot"></span>
                    Internal tool
                </div>
                <div class="auth-title">Reporting Portal</div>
                <div class="auth-subtitle">Training coordinator access only.</div>

                <form asp-controller="Account" asp-action="Login" method="post" style="display:flex; flex-direction:column; gap:14px;">
                    @Html.AntiForgeryToken()

                    @if (ViewBag.Error != null)
                    {
                        <div class="validation-error">@ViewBag.Error</div>
                    }

                    <div class="field">
                        <label asp-for="Email">Email address</label>
                        <input asp-for="Email" type="email" placeholder="you@taalam.bh" autocomplete="username" />
                    </div>

                    <div class="field">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" type="password" placeholder="••••••••••" autocomplete="current-password" />
                    </div>

                    <button type="submit" class="btn-primary">Sign in</button>
                </form>
            </div>

            <div class="auth-footer-text">© @DateTime.Now.Year Taalam Training Institute · Manama, Bahrain</div>
        </div>

        <div class="auth-right">
            <div class="auth-right-eyebrow">Reporting Portal</div>
            <div class="auth-right-headline">Operational insights for smarter decisions.</div>
            <div class="auth-right-body">Read-only enrollment, certification, instructor, and revenue analytics across the institute.</div>
        </div>
    </div>
</body>
</html>
