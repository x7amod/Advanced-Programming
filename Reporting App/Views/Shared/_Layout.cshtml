<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Taalam Reporting Portal</title>

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom Reporting Styles -->
    <link rel="stylesheet" href="~/css/reporting.css" />
</head>
<body>

    @* ──── TOPBAR / HEADER ──── *@
    @if (Context.Session.GetString("JwtToken") != null)
    {
        var userEmail = Context.Session.GetString("UserEmail") ?? "coordinator@taalam.bh";
        var initials = string.Join("", userEmail.Split('@')[0].Split(' ').Select(s => s.Length > 0 ? s[0].ToString().ToUpper() : ""));

        <header class="rp-topbar">
            <div class="rp-topbar-brand">
                <img src="~/assets/logo.svg" alt="Taalam" onerror="this.style.display='none'" />
                <div class="rp-topbar-divider"></div>
                <span class="rp-topbar-label">Reporting Portal</span>
            </div>

            <div class="rp-topbar-spacer"></div>

            <div class="rp-topbar-right">
                <div class="rp-avatar">@initials</div>
                <div class="rp-user-info">
                    <span class="rp-user-name">@userEmail.Split('@')[0]</span>
                    <span class="rp-user-email">@userEmail</span>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0; display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="rp-logout-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 4h5v16h-5" />
                            <path d="m10 8-4 4 4 4" />
                            <path d="M6 12h11" />
                        </svg>
                        Logout
                    </button>
                </form>
            </div>
        </header>
    }

    @* ──── MAIN CONTENT ──── *@
    <main class="rp-main">
        @RenderBody()
    </main>

    @* ──── FOOTER ──── *@
    <footer class="rp-footer">
        Data is read-only. No changes can be made from this portal.
    </footer>

    @* ──── SCRIPTS ──── *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
